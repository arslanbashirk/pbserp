@model PBS.ERP.Shared.Models.Entity;
@{
    ViewBag.Title = "Dynamic CRUD";
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css">
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
}
<script>
    window.PreFilledData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
         ViewBag.PreFilledData ?? new Dictionary<string, object>()
    ));
</script>
<div>
    <h2 class="mb-3 text-capitalize" id="table"><span id="table-description">@Model.Name</span> (@Model.Description)</h2>
    <input type="hidden" id="uid" value="@Model.UID" />
    <input type="hidden" id="path" value="@ViewBag.Path" />
    <hr />
    @await Html.PartialAsync("_PartialCrud")
</div>

@section Scripts {

    <!-- Core helper: must come before CRUD operations -->
    <script src="~/js/save-data.js" asp-append-version="true"></script>

    <!-- Third-party plugins used by grid/form templates -->
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>

    <!-- DataTables export dependencies -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>

    <!-- DataTables buttons -->
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>

    <!-- Select2 used by dynamic form -->
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <!-- Your reusable templates -->
    <script src="~/js/crud-build-form.js" asp-append-version="true"></script>
    <script src="~/js/crud-grid-render.js" asp-append-version="true"></script>

    <!-- CRUD operations should come after templates -->
    <script src="~/js/crud-operations.js" asp-append-version="true"></script>

    @if (User.IsInRole("Admin"))
    {
        <script src="https://code.highcharts.com/highcharts.js"></script>
        <script src="~/js/our-visualization.js" asp-append-version="true"></script>
    }

    <script>
        $(document).ready(function () {

            if (!window.PbsErp) {
                console.error("PbsErp helper is missing. Check save-data.js.");
                alert("API helper is missing.");
                return;
            }

            if (!window.PbsCrudPage) {
                console.error("PbsCrudPage is missing. Check crud-operations.js.");
                alert("CRUD operation template is missing.");
                return;
            }

            if (!window.PbsCrudTemplates || typeof window.PbsCrudTemplates.buildForm !== "function") {
                console.error("buildForm template is missing. Check crud-build-form.js.");
                alert("Form template is missing.");
                return;
            }

            if (typeof window.loadGrid !== "function") {
                alert("Grid template is missing.");
                return;
            }

            window.crudPage = window.PbsCrudPage.init({
                preFilledData: window.PreFilledData || {},
                buildForm: window.PbsCrudTemplates.buildForm,
                gridMode: "all",
                gridOptions: {
                    maxVisibleColumns: 5
                },
                includeDynamicFieldsInUpload: false
            });
        });
    </script>
}

<style>
    .viz-card {
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        box-shadow: 0 8px 22px rgba(15, 23, 42, 0.06);
        overflow: hidden;
        margin-top: 15px;
    }

    .viz-card-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 14px 18px;
        background: linear-gradient(135deg, #f8fafc, #eef2ff);
        border-bottom: 1px solid #e5e7eb;
        cursor: pointer;
    }

    .viz-title {
        display: flex;
        align-items: center;
        gap: 10px;
        font-weight: 700;
        color: #1f2937;
        font-size: 16px;
    }

    .viz-title-icon {
        width: 34px;
        height: 34px;
        border-radius: 10px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #2563eb;
        color: white;
        font-size: 17px;
    }

    .viz-subtitle {
        font-size: 12px;
        color: #6b7280;
        font-weight: 400;
        margin-top: 2px;
    }

    .viz-toggle-btn {
        border: none;
        background: #ffffff;
        color: #2563eb;
        border-radius: 999px;
        padding: 6px 12px;
        font-size: 13px;
        font-weight: 600;
        box-shadow: 0 1px 4px rgba(0,0,0,0.08);
    }

    .viz-card-body {
        display: none;
        padding: 18px;
    }

    .viz-filter-box {
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 15px;
        margin-bottom: 18px;
    }

        .viz-filter-box .form-label {
            font-size: 12px;
            font-weight: 700;
            color: #374151;
            margin-bottom: 5px;
        }

        .viz-filter-box .form-control,
        .viz-filter-box .form-select {
            font-size: 13px;
            border-radius: 9px;
        }

    .viz-action-bar {
        display: flex;
        align-items: end;
        height: 100%;
    }

        .viz-action-bar .btn {
            border-radius: 9px;
            font-weight: 600;
            width: 100%;
        }

    .viz-result-area {
        display: flex;
        gap: 18px;
        width: 100%;
        align-items: stretch;
    }

    .viz-chart-panel,
    .viz-table-panel {
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        background: #ffffff;
        padding: 12px;
    }

    .viz-chart-panel {
        width: 70%;
        min-height: 430px;
    }

    .viz-table-panel {
        width: 30%;
        max-height: 430px;
        overflow: auto;
    }

    #chartContainer {
        width: 100%;
        height: 390px;
    }

    #summaryTable {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

        #summaryTable th {
            background: #f3f4f6;
            color: #374151;
            font-weight: 700;
            padding: 8px;
            border: 1px solid #e5e7eb;
            position: sticky;
            top: 0;
            z-index: 1;
        }

        #summaryTable td {
            padding: 7px 8px;
            border: 1px solid #e5e7eb;
            color: #374151;
        }

        #summaryTable tbody tr:nth-child(even) {
            background: #f9fafb;
        }

    .viz-empty-state {
        color: #6b7280;
        font-size: 13px;
        text-align: center;
        padding: 35px 10px;
    }

    @@media (max-width: 992px) {
        .viz-result-area {
            flex-direction: column;
        }

        .viz-chart-panel,
        .viz-table-panel {
            width: 100%;
        }
    }
</style>