@model PBS.ERP.Shared.FileTableView;
@{
    ViewBag.Title = "Dynamic CRUD";
    Layout = "_Layout";
            <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
            <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css">
            <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
}

<style>
    .dt-buttons {
        display: none !important;
    }

    .mb-3 {
        margin-bottom: 15px;
    }

    thead {
        background-color: blue !important;
        color: white;
    }

    .select2-container .select2-selection--single {
        height: 36px;
    }

    .select2-container--default .select2-selection--single .select2-selection__rendered {
        line-height: 36px;
    }

    .select2-container--default .select2-selection--single .select2-selection__arrow {
        height: 36px;
    }

    
</style>



<div class="d-flex justify-content-between align-items-center mb-3">

    <h2 class="mb-0 text-capitalize" id="table-title">@Model.Title</h2>

    <button class="btn btn-info text-white" onclick="goBackAndRefresh()">
        <i class="bi bi-arrow-left"></i> Go Back
    </button>


</div>
<script>
    window.PreFilledData = @Html.Raw(Json.Serialize(
        Model.fields
            .Where(x =>
                x.Key != "__RequestVerificationToken" &&
                x.Key != "UID" &&
                x.Key != "ID" &&
                x.Key != "Id")
            .ToDictionary(x => x.Key, x => x.Value)
    ));

    function goBackAndRefresh() {
        window.history.back();
    }
</script>
<input type="hidden" id="uid" value="@Model.Entity.UID" />
<input type="hidden" id="path" value="@ViewBag.Path" />
<input type="hidden" id="ForColumns" value="@Model.Columns" />
<input type="hidden" id="FormatTable" value="@Model.FormatTable" />
<input type="hidden" id="FormatColumns" value="@Model.FormatColumns" />
<input type="hidden" id="FormatFilter" value="@Model.FormatFilter" />
<hr />
<div class="col-md-8">
    @if (Model.Reference.Count > 0)
    {
        <p>
            <b>Excluded Columns: </b>
            @foreach (var field in Model.Reference)
            {
                <span>@field.Key.Replace("_Text", ""): <b>@field.Value</b></span>
            }
        </p>
    }
    @if (Model.Grid?.FormatColumns != null)
    {
        <p><b>Fixed Columns: </b>@Model.Grid?.FormatColumns</p>
    }
    @if (Model.Columns != null)
    {
        <p><b>Editable Columns: </b>@Model.Columns</p>
    }
</div>
<div class="col-md-4">
    <button class="btn btn-info text-white" id="btnDownloadFormat" style="display:none">
        <i class="bi bi-arrow-down"></i> Download Format
    </button>
    <table id="hiddenTable" style="display:none !important;"></table>
</div>
<hr/>
<div class="mb-3">
    <label class="form-label">Import CSV / Excel</label>
    <input type="file" id="importFile" class="form-control" accept=".csv,.xlsx,.xls" />
    <button type="button" class="btn btn-success mt-2" onclick="uploadFile()">
        <i class="bi bi-upload"></i> Upload & Import
    </button>
</div>
<hr />



<!-- ===================== FORM ===================== -->
<div id="form-container">
    <form id="dynamicForm" class="row">
    </form>
    <div class="mt-3" style="margin-top:10px">
        <button type="button" class="btn btn-primary" onclick="save()">Save</button>
        <button type="button" class="btn btn-secondary" onclick="resetForm()">Reset</button>
    </div>
</div>

<hr />
<!-- ===================== GRID ===================== -->
<div class="table-responsive">
    <table class="table table-bordered table-striped" id="grid">
        <thead></thead>
        <tbody></tbody>
    </table>
</div>
<div id="uploadOverlay" style=" display:none; position:fixed;top:0; left:0;
    width:100%; height:100%; background:rgba(0,0,0,0.5);
z-index:9999;justify-content:center;align-items:center;">
    <div class="bg-white p-4 rounded shadow text-center" style="width:300px;">
        <h5>Uploading...</h5>

        <div class="progress mt-3">
            <div id="uploadProgressBar"
                 class="progress-bar progress-bar-striped progress-bar-animated"
                 style="width: 0%">
                0%
            </div>
        </div>

        <small class="text-muted mt-2 d-block">Please wait</small>
    </div>
</div>


@section Scripts {

    <!-- Core helper: must come before CRUD operations -->
    <script src="~/js/save-data.js" asp-append-version="true"></script>

    <!-- Third-party plugins used by grid/form templates -->
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>

    <!-- DataTables export dependencies -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>

    <!-- DataTables buttons -->
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>

    <!-- Select2 used by dynamic form -->
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <!-- Your reusable templates -->
    <script src="~/js/crud-build-form.js" asp-append-version="true"></script>
    <script src="~/js/crud-grid-render.js" asp-append-version="true"></script>
    <script src="~/js/crud-format-export.js" asp-append-version="true"></script>

    <!-- CRUD operations should come after templates -->
    <script src="~/js/crud-operations.js" asp-append-version="true"></script>

    @if (User.IsInRole("Admin"))
    {
        <script src="https://code.highcharts.com/highcharts.js"></script>
        <script src="~/js/our-visualization.js" asp-append-version="true"></script>
    }

    <script>
        $(document).ready(function () {
            $("#dynamicForm").closest("#form-container").hide();
            if (!window.PbsErp) {
                console.error("PbsErp helper is missing. Check save-data.js.");
                alert("API helper is missing.");
                return;
            }

            if (!window.PbsCrudPage) {
                console.error("PbsCrudPage is missing. Check crud-operations.js.");
                alert("CRUD operation template is missing.");
                return;
            }

            if (!window.PbsCrudTemplates || typeof window.PbsCrudTemplates.buildForm !== "function") {
                console.error("buildForm template is missing. Check crud-build-form.js.");
                alert("Form template is missing.");
                return;
            }

            if (!window.PbsCrudTemplates || typeof window.PbsCrudTemplates.loadGrid !== "function") {
                console.error("loadGrid template is missing. Check crud-grid-render.js.");
                alert("Grid template is missing.");
                return;
            }


            window.crudPage = window.PbsCrudPage.init({
                preFilledData: window.PreFilledData || {},
                buildForm: window.PbsCrudTemplates.buildForm,
                gridMode: "showInList",
                includeDynamicFieldsInUpload: true,
                afterMetadataLoaded: function () {
                    if (window.formatExport) {
                        window.formatExport.loadFormat();
                    }
                }

            });

            window.formatExport = window.PbsFormatExport.init({
                formatTableSelector: "#FormatTable",
                formatColumnsSelector: "#FormatColumns",
                formatFilterSelector: "#FormatFilter",
                forColumnsSelector: "#ForColumns",
                preFilledData: window.PreFilledData || {},
                downloadButtonSelector: "#btnDownloadFormat",
                hiddenTableSelector: "#hiddenTable",
                fileNameSelector: "#table-title"
            });

        });
    </script>
}