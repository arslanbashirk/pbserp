@model List<PBS.ERP.Shared.Models.SurveyModel.SurveyViewModel>

@{
    ViewData["Title"] = "Survey List";
    Layout = "_Staff";
    ViewBag.Menu = "Subject";
}

<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">

<style>
    .survey-card {
        border: none;
        border-radius: 12px;
        transition: 0.3s;
    }

        .survey-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        }

    .badge-active {
        background-color: #28a745;
    }

    .badge-inactive {
        background-color: #dc3545;
    }

    .meta {
        font-size: 13px;
        color: #6c757d;
    }
</style>

    <div class="row">
        
        @if(Model!=null && Model.Any()){
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3><i class="fa fa-chart-bar"></i> Survey List</h3>
            </div>
            @foreach (var item in Model)
            {
                <div class="col-md-6 mb-3">
                    <div class="card survey-card p-3 h-100 shadow-sm">

                        <!-- Header -->
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div>
                                <h5 class="mb-1">
                                    <a href="@Url.Action("Entity", "Subject", new { id = item.UID })"
                                       class="text-decoration-none text-primary fw-semibold">
                                        @item.ShortVersion
                                    </a>
                                </h5>
                                <small class="text-muted">@item.Name</small>
                            </div>

                            <span class="badge @(item.IsActive ? "badge-active" : "badge-inactive") px-2 py-1">
                                @(item.IsActive ? "Active" : "Inactive")
                            </span>
                        </div>

                        <hr class="my-2" />

                        <!-- Metadata (single line) -->
                        <div class="d-flex flex-wrap gap-3 text-muted small">
                            <div>
                                <i class="fa fa-calendar me-1"></i>
                                <span>Execution Year:</span>
                                <strong class="text-dark">@item.ExecutionYear</strong>
                            </div>

                            <div>
                                <i class="fa fa-clock me-1"></i>
                                <span>Reference Period:</span>
                                <strong class="text-dark">@item.ReferencePeriod</strong>
                            </div>
                        </div>

                    </div>
                </div>
            }

        }
        else
        {
        <div class="empty-survey-box">
            <h4>You Are Not Subject Team Member</h4>

            <p>
                You are currently not assigned as a <strong>Subject Team Member</strong>
                for any active survey.
            </p>

            <p class="text-muted mb-0">
                Once assigned, you will be able to define questionnaires, test the application,
                and view survey data.
            </p>
        </div>
        }

    </div>
<style>
    .empty-survey-box {
        max-width: 650px;
        margin: 20px auto;
        padding: 20px 15px;
        text-align: center;
        background-color: #ffffff;
        border: 1px solid #dee2e6;
        border-radius: 10px;
        box-shadow: 0 4px 14px rgba(0, 0, 0, 0.06);
    }

        .empty-survey-box h4 {
            margin-bottom: 12px;
            font-weight: 600;
            color: #212529;
        }

        .empty-survey-box p {
            margin-bottom: 8px;
            font-size: 15px;
            color: #495057;
        }
</style>