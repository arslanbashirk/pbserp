@{
    ViewData["Title"] = "PBS ERP Login";
}

<div class="container-fluid d-flex align-items-center justify-content-center" style="background-color:#f4f6f9; min-height:100vh;">

    <div class="card shadow-lg" style="width:420px; border-radius:10px;">

        <!-- Header -->
        <div class="text-center bg-success text-white p-3" style="border-top-left-radius:10px; border-top-right-radius:10px;">
            <img src="~/images/pbslogo.png" alt="PBS Logo" style="height:70px;" />
            <h5 class="mt-2 mb-0">Census & Surveys ERP</h5>
            <small>Pakistan Bureau of Statistics</small>
        </div>

        <!-- Body -->
        <div class="card-body p-4">

            <h4 class="text-center mb-4 fw-bold text-success">System Login</h4>

            <div id="loginMessage" class="alert d-none"></div>

            <form id="loginForm">

                <div class="mb-3">
                    <label for="username" class="form-label fw-semibold">Email or CNIC</label>
                    <input type="text"
                           name="username"
                           class="form-control"
                           id="username"
                           placeholder="Enter your username"
                           required />
                </div>

                <div class="mb-3">
                    <label for="password" class="form-label fw-semibold">Password</label>
                    <input type="password"
                           name="password"
                           class="form-control"
                           id="password"
                           placeholder="Enter your password"
                           required />
                </div>

                <div class="form-check mb-3">
                    <input type="checkbox"
                           name="rememberMe"
                           class="form-check-input"
                           id="rememberMe" />
                    <label class="form-check-label" for="rememberMe">Remember Me</label>
                </div>

                <button type="submit" id="loginBtn" class="btn btn-success w-100 fw-bold">
                    Login to System
                </button>

            </form>

            <div class="d-flex justify-content-between align-items-center mt-2">
                <a href="/Account/Register"
                   class="text-decoration-none medium">
                    <i class="fas fa-user-plus me-1"></i>
                    Register?
                </a>

                <a href="/Account/Forgot"
                   class="text-decoration-none medium">
                    <i class="fas fa-key me-1"></i>
                    Forgot Password?
                </a>
            </div>

        </div>

        <!-- Footer -->
        <div class="text-center bg-success p-2">
            <small class="text-white">
                Copyrights: © @DateTime.Now.Year <br />
                Pakistan Bureau of Statistics<br />
                Government of Pakistan
            </small>
        </div>

    </div>

</div>

@section Scripts {
    <script>
        let loginInProgress = false;

        document.getElementById("loginForm").addEventListener("submit", async function (e) {
            e.preventDefault();

            if (loginInProgress) {
                return;
            }

            loginInProgress = true;

            const form = this;
            const username = document.getElementById("username").value.trim();
            const password = document.getElementById("password").value;
            const rememberMe = document.getElementById("rememberMe").checked;

            const loginBtn = document.getElementById("loginBtn");
            const loginMessage = document.getElementById("loginMessage");

            const originalButtonHtml = loginBtn.innerHTML;

            let redirecting = false;

            loginMessage.classList.add("d-none");
            loginMessage.classList.remove("alert-danger", "alert-success");
            loginMessage.innerHTML = "";

            if (!username || !password) {
                loginInProgress = false;
                showLoginMessage("Login ID and password are required.", "danger");
                return;
            }

            setLoginLoading(loginBtn, form, "Authenticating...");

            try {
                const response = await fetch(apiUrl("/api/auth/authenticate"), {
                    method: "POST",
                    credentials: "include",
                    headers: {
                        "Content-Type": "application/json",
                        "Accept": "application/json"
                    },
                    body: JSON.stringify({
                        Username: username,
                        Password: password,
                        RememberMe: rememberMe
                    })
                });

                let data = null;

                try {
                    data = await response.json();
                } catch {
                    data = null;
                }

                if (!response.ok) {
                    let message = "Invalid login attempt.";

                    if (typeof data === "string") {
                        message = data;
                    } else if (data && data.message) {
                        message = data.message;
                    } else if (data && data.Message) {
                        message = data.Message;
                    }

                    showLoginMessage(message, "danger");
                    return;
                }

                const isSuccess =
                    data &&
                    (
                        data.success === true ||
                        data.Success === true
                    );

                const token =
                    data?.token ||
                    data?.Token ||
                    data?.accessToken ||
                    data?.AccessToken;

                if (!isSuccess || !token) {
                    showLoginMessage("Login successful, but token was not received from API.", "danger");
                    return;
                }

                const user =
                    data.user ||
                    data.User ||
                    null;

                const accessTokenExpiresAtUtc =
                    data.accessTokenExpiresAtUtc ||
                    data.AccessTokenExpiresAtUtc ||
                    "";

                const redirectUrl =
                    data.redirectUrl ||
                    data.RedirectUrl ||
                    "/Home/Index";

                clearAuthStorage();

                localStorage.setItem("pbs_erp_token", token);
                localStorage.setItem("pbs_erp_user", JSON.stringify(user));
                localStorage.setItem("pbs_erp_token_expires", accessTokenExpiresAtUtc);
                localStorage.setItem("pbs_erp_remember", rememberMe ? "true" : "false");
                localStorage.setItem("pbs_erp_redirect_url", redirectUrl);

                setLoginLoading(loginBtn, form, "Creating local session...");

                const localSignInResponse = await fetch("/Account/SignInFromApiToken", {
                    method: "POST",
                    credentials: "same-origin",
                    headers: {
                        "Content-Type": "application/json",
                        "Accept": "application/json"
                    },
                    body: JSON.stringify({
                        Token: token,
                        RememberMe: rememberMe
                    })
                });

                let localSignInData = null;

                try {
                    localSignInData = await localSignInResponse.json();
                } catch {
                    localSignInData = null;
                }

                if (!localSignInResponse.ok) {
                    let message = "API login succeeded, but local MVC session could not be created.";

                    if (localSignInData && localSignInData.message) {
                        message = localSignInData.message;
                    } else if (localSignInData && localSignInData.Message) {
                        message = localSignInData.Message;
                    }

                    showLoginMessage(message, "danger");
                    return;
                }

                const localSignInSuccess =
                    !localSignInData ||
                    localSignInData.success === true ||
                    localSignInData.Success === true;

                if (!localSignInSuccess) {
                    let message = "API login succeeded, but local MVC session was rejected.";

                    if (localSignInData && localSignInData.message) {
                        message = localSignInData.message;
                    } else if (localSignInData && localSignInData.Message) {
                        message = localSignInData.Message;
                    }

                    showLoginMessage(message, "danger");
                    return;
                }

                redirecting = true;

                showLoginMessage("Login successful. Redirecting...", "success");
                setLoginLoading(loginBtn, form, "Redirecting...");

                window.location.href = redirectUrl;
            }
            catch (error) {
                console.error("Login error:", error);
                showLoginMessage("Server error while logging in. Please try again.", "danger");
            }
            finally {
                if (!redirecting) {
                    loginInProgress = false;
                    resetLoginButton(loginBtn, form, originalButtonHtml);
                }
            }
        });

        function clearAuthStorage() {
            localStorage.removeItem("pbs_erp_token");
            localStorage.removeItem("pbs_erp_user");
            localStorage.removeItem("pbs_erp_token_expires");
            localStorage.removeItem("pbs_erp_redirect_url");
            localStorage.removeItem("pbs_erp_remember");

            sessionStorage.removeItem("pbs_erp_token");
            sessionStorage.removeItem("pbs_erp_user");
            sessionStorage.removeItem("pbs_erp_token_expires");
            sessionStorage.removeItem("pbs_erp_redirect_url");
            sessionStorage.removeItem("pbs_erp_remember");
        }

        function setLoginLoading(button, form, text) {
            button.disabled = true;
            button.setAttribute("aria-disabled", "true");

            form.setAttribute("aria-busy", "true");

            button.innerHTML =
                '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>' +
                text;
        }

        function resetLoginButton(button, form, originalHtml) {
            button.disabled = false;
            button.removeAttribute("aria-disabled");

            form.removeAttribute("aria-busy");

            button.innerHTML = originalHtml || "Login to System";
        }

        function showLoginMessage(message, type) {
            const loginMessage = document.getElementById("loginMessage");

            loginMessage.classList.remove("d-none", "alert-danger", "alert-success");
            loginMessage.classList.add("alert-" + type);
            loginMessage.innerHTML = message;
        }

    </script>
}