@model PBS.ERP.Shared.Models.Entity;
@{
    ViewBag.Title = "Dynamic CRUD";
    Layout = "_Staff";
                <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
                <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css">
                <style>
                    .mb-3 {
                        margin-bottom: 15px;
                    }
                    thead{
                        background-color:blue !important;
                        color:white;
                    }

                .breadcrumbParent {
                    display: none;
                }
                </style>
   
}

<div class="card  bg-white">
    <div class="card-body">
        <h2 class="mb-3 text-capitalize" id="table">@Model.Description</h2>
        <input type="hidden" id="aacode" value="@ViewBag.Code" />
        <input type="hidden" id="uid" value="@Model.UID" />
        <input type="hidden" id="aawhere" value="@ViewBag.Where" />
        <input type="hidden" id="path" value="@ViewBag.Path" />
        <hr />
        <!-- ===================== FORM ===================== -->
        <div id="form-container">
            <form id="dynamicForm" class="row">
            </form>
            <div class="mt-3" style="margin-top:10px">
                <button id="btnSave" type="button" class="btn btn-primary" onclick="save()">Save and Close</button>
            </div>
        </div>
    </div>

</div>

@section scripts{
    <script src="~/js/save-data.js" asp-append-version="true"></script>

    <script>


    $(document).ready(function () {
        const uid = $("#uid").val();
        const PATH = $("#path").val();
        const table = $("#table").text();
        let metadata = [];
        loadMetadata()
            function loadMetadata() {
                window.PbsErp.call("metadata.get", { table: uid }, {
                    success: function (response) {
                        if (!response.Success) {
                            alert(response.Message || "Failed to load metadata.");
                            return;
                        }

                        metadata = response.Data || [];

                        buildForm(metadata);
                        loadGrid();
                    },
                    error: function (err) {
                        alert(err.Message || "Server error while loading metadata.");
                    }
                });
            }

        function buildForm(fields) {
            const $form = $('#dynamicForm');
            $form.empty();
            $form.append('<input type="hidden" id="UID" name="UID"/>');

            let currentSection = null;

            fields.forEach(f => {

                if (f.IsReadonly) return;
                if (f.ColumnName == "AreaCode") return;
                // ---------- SECTION HEADER ----------
                if (f.SectionNumber != null && f.SectionNumber !== currentSection) {
                    currentSection = f.SectionNumber;
                    if (f.SectionName) {
                        $form.append(`<div class="col-md-12 mt-3"><h3>${f.SectionName}</h3><hr/></div>`);
                    } else {
                        $form.append(`<div class="col-md-12 mt-3"></div>`);
                    }
                }

                // ---------- INPUT HTML ----------
                let inputHtml = '';
                const required = f.IsRequired ? 'required' : '';
                const readonly = f.IsReadonly ? 'readonly' : '';
                const placeholder = f.Placeholder ?? '';
                // --- HANDLE BOOLEAN INPUTS ---
                if (f.InputType === 'boolean') {
                    inputHtml = `<div>
                        <div class="form-check form-check-inline">
                            <input class="form-check-input"
                                    type="radio"
                                    name="${f.ColumnName}"
                                    id="${f.ColumnName}_true"
                                    value=true
                                    ${required}
                                    ${readonly} checked>

                            <label class="form-check-label" for="${f.ColumnName}_true">
                                ${f.TrueLabel ?? 'True'}
                            </label>
                        </div>

                        <div class="form-check form-check-inline ms-3">
                            <input class="form-check-input"
                                    type="radio"
                                    name="${f.ColumnName}"
                                    id="${f.ColumnName}_false"
                                    value=false
                                    ${readonly}>

                            <label class="form-check-label" for="${f.ColumnName}_false">
                                ${f.FalseLabel ?? 'False'}
                            </label>
                        </div>

                        ${f.Tooltip ? `<div><small class="text-muted">${f.Tooltip}</small></div>` : ''}

                    </div>`;
                }
                else{
                    switch (f.InputType) {
                        case 'text':
                        case 'number':
                        case 'email':
                        case 'url':
                        case 'tel':
                        case 'password':
                        case 'color':
                        case 'range':
                        case 'month':
                        case 'week':
                        case 'search':
                        case 'time':
                        case 'datetime-local':
                            inputHtml = `<input type="${f.InputType}" class="form-control" name="${f.ColumnName}" placeholder="${placeholder}" ${required} ${readonly} />`;
                            break;

                        case 'date':
                            inputHtml = `<input type="date" class="form-control" name="${f.ColumnName}" ${required} ${readonly} />`;
                            break;

                        case 'textarea':
                            inputHtml = `<textarea class="form-control" name="${f.ColumnName}" placeholder="${placeholder}" ${required} ${readonly}></textarea>`;
                            break;

                        case 'checkbox':
                            inputHtml = `<div class="form-check">
                                        <input class="form-check-input" type="checkbox" name="${f.ColumnName}" value="1" ${readonly} />
                                        <label class="form-check-label">${f.DisplayLabel ?? f.ColumnName}</label>
                                        </div>`;
                            break;

                        case 'radio':
                            // placeholder container; will populate options later
                            inputHtml = `<div id="radioContainer_${f.ColumnName}"></div>`;
                            break;

                        case 'select':
                            inputHtml = `<select class="form-select" name="${f.ColumnName}" id="${f.ColumnName}" ${required} ${readonly}>
                                        <option value="">-- Select --</option>
                                        </select>`;
                            break;

                        case 'file':
                            inputHtml = `<input type="file" class="form-control" name="${f.ColumnName}" ${required} ${readonly} />`;
                            break;

                        default:
                            // fallback to text input
                            inputHtml = `<input type="text" class="form-control" name="${f.ColumnName}" placeholder="${placeholder}" ${required} ${readonly} />`;
                            break;
                    }
                }
                

                // ---------- APPEND FIELD ----------
                if (f.InputType !== 'checkbox' && f.InputType !== 'radio') {
                    // Label outside for non-checkbox/radio
                    $form.append(`
                    <div class="col-md-4 mb-3">
                        <label class="form-label">${f.DisplayLabel ?? f.ColumnName} ${f.IsRequired ? '<span class="text-danger">*</span>' : ''}</label>
                        ${inputHtml}
                        ${f.Tooltip ? `<small class="text-muted">${f.Tooltip}</small>` : ''}
                    </div>
                `);
                } else {
                    // Checkbox or radio container
                    $form.append(`
                    <div class="col-md-4 mb-3">
                        <label class="form-label">${f.InputType === 'radio' ? f.DisplayLabel ?? f.ColumnName : ''} ${f.IsRequired ? '<span class="text-danger">*</span>' : ''}</label>
                        ${inputHtml}
                        ${f.Tooltip ? `<small class="text-muted">${f.Tooltip}</small>` : ''}
                    </div>
                `);
                }
                var acode=$("#aacode").val();
                // ---------- LOAD DROPDOWN / RADIO DATA ----------
                    if ((f.InputType === 'select' || f.InputType === 'radio') && f.DropdownSourceTable) {

                        window.PbsErp.call("lookup.get", {
                            table: f.DropdownSourceTable,
                            valueCol: f.DropdownValueColumn,
                            textCol: f.DropdownTextColumn,
                            where: f.DropdownWhere,
                            order: f.DropdownOrderBy
                        }, {
                            success: function (response) {

                                if (!response.Success) {
                                    alert(response.Message || "Failed to load lookup data.");
                                    return;
                                }

                                const rows = response.Data || [];

                                if (f.InputType === 'select') {
                                    rows.forEach(r => {
                                        $('#' + f.ColumnName).append(`<option value="${r.value}">${r.text}</option>`);
                                    });
                                }
                                else if (f.InputType === 'radio') {
                                    const $container = $(`#radioContainer_${f.ColumnName}`);

                                    rows.forEach(r => {
                                        const radioHtml = `
                                        <div class="form-check">
                                            <input class="form-check-input"
                                                   type="radio"
                                                   name="${f.ColumnName}"
                                                   value="${r.value}"
                                                   id="${f.ColumnName}_${r.value}" />
                                            <label class="form-check-label"
                                                   for="${f.ColumnName}_${r.value}">
                                                   ${r.text}
                                            </label>
                                        </div>
                                    `;

                                        $container.append(radioHtml);
                                    });
                                }
                            },
                            error: function (err) {
                                alert(err.Message || "Server error while loading lookup data.");
                            }
                        });
                    }
                
            });
        }

            window.save = function () {
                $("#btnSave").prop("disabled", true);

                var code = $('#aacode').val();
                var id = $('#UID').val();
                var data = {};
                const isUpdate = id && id != '';

                $('#dynamicForm').find('input, select, textarea').each(function () {
                    if (this.type === 'checkbox') {
                        data[this.name] = this.checked ? 1 : 0;
                    }
                    else if (this.type === 'radio') {
                        // Only set value if this radio button is checked
                        if (this.checked) {
                            data[this.name] = this.value;
                        }
                    }
                    else if ($(this).val() != "") {
                        data[this.name] = $(this).val();
                    }
                });

                data['AreaCode'] = code;

                window.PbsErp.call("crud.save", {
                    table: uid,
                    id: isUpdate ? id : null,
                    fields: data
                }, {
                    success: function (res) {
                        $("#btnSave").prop("disabled", false);

                        if (res.Success) {
                            alert(isUpdate ? 'Updated successfully' : 'Saved successfully');

                            window.location.href = '/PPII/Home?id=2f0227ed-af86-44f4-be5d-2407ab793052';
                        }
                        else {
                            alert(res.Message || "Save failed.");
                        }
                    },
                    error: function (err) {
                        $("#btnSave").prop("disabled", false);

                        alert("Network or Server Error: " + (err.Message || "Unknown error"));
                    }
                });
            }

        window.resetForm = function () {
            $('#dynamicForm')[0].reset();
            $('#UID').val('');
        }

        function loadGrid() {
            var code = $("#aacode").val();

            if (!code) return;

            $.get('/PPII/Entity', { id: code })
                .done(function (data) {
                    if (data) {
                        if (data.Respondent) {
                            editRecord(data.Respondent);
                        }
                        
                    }
                })
                .fail(function (err) {
                    console.error("Error fetching entity:", err);
                });
        }



        // Event delegation for dynamically generated buttons
        $('#grid tbody').on('click', '.edit-btn', function () {
            editRecord($(this).data('id'));
        });

        $('#grid tbody').on('click', '.delete-btn', function () {
            deleteRecord($(this).data('id'));
        });


        function setDateInput(name, val) {
            if (!val) {
                $(`[name='${name}']`).val('');
                return;
            }

            let dateStr = '';

            // Handle /Date(1532400000000)/ format
            if (val.startsWith('/Date(')) {
                const timestamp = parseInt(val.replace(/\/Date\((\d+)\)\//, '$1'));
                const dateObj = new Date(timestamp);
                const yyyy = dateObj.getFullYear();
                const mm = String(dateObj.getMonth() + 1).padStart(2, '0');
                const dd = String(dateObj.getDate()).padStart(2, '0');
                dateStr = `${yyyy}-${mm}-${dd}`;
            }
            // Handle yyyy-MM-dd or ISO string
            else {
                const dateObj = new Date(val);
                if (isNaN(dateObj)) {
                    dateStr = '';
                } else {
                    const yyyy = dateObj.getFullYear();
                    const mm = String(dateObj.getMonth() + 1).padStart(2, '0');
                    const dd = String(dateObj.getDate()).padStart(2, '0');
                    dateStr = `${yyyy}-${mm}-${dd}`;
                }
            }

            $(`[name='${name}']`).val(dateStr);
        }


        function parseDotNetDate(dotNetDateStr) {
            // Example input: "/Date(1532458800000)/"
            const match = /\/Date\((\d+)\)\//.exec(dotNetDateStr);
            if (match) {
                const timestamp = parseInt(match[1], 10);
                return new Date(timestamp);
            }
            return null;
        }

        function formatDotNetDate(dotNetDateStr) {
            // Example input: "/Date(1532458800000)/"
            const timestamp = parseInt(dotNetDateStr.replace(/\/Date\((\d+)\)\//, '$1'), 10);
            const date = new Date(timestamp);

            const mm = String(date.getMonth() + 1).padStart(2, '0');
            const dd = String(date.getDate()).padStart(2, '0');
            const yyyy = date.getFullYear();

            return `${mm}/${dd}/${yyyy}`;
        }


        // ----------------- EDIT RECORD -----------------
            function editRecord(id) {
                window.PbsErp.call("crud.record", {
                    table: uid,
                    id: id
                }, {
                    success: function (res) {

                        if (!res.Success) {
                            alert(res.Message || "Failed to load record.");
                            return;
                        }

                        const recordArr = res.Data || {};
                        const record = {};

                        Object.keys(recordArr).forEach(key => {
                            record[key] = recordArr[key];
                        });

                        $('#UID').val(record.UID);

                        metadata.forEach(f => {
                            let val = record[f.ColumnName];
                            let $el = $(`[name='${f.ColumnName}']`);

                            if (!$el.length) return; // safety check

                            if (f.InputType === 'checkbox') {
                                $el.prop('checked', val == 1 || val === true);
                            }
                            else if (f.InputType === 'boolean') {
                                const name = f.ColumnName;

                                let boolValue = null;
                                if (val === true) {
                                    boolValue = "true";
                                }
                                else if (val === false) {
                                    boolValue = "false";
                                }

                                // Clear all first, then check the correct radio
                                $(`input[name='${name}']`).prop("checked", false);

                                if (boolValue !== null) {
                                    $(`input[name='${name}'][value='${boolValue}']`).prop("checked", true);
                                }
                            }
                            else if (f.InputType === 'date') {
                                setDateInput(f.ColumnName, val);
                            }
                            else if (f.InputType === 'select') {
                                if (typeof val === 'boolean') {
                                    val = val ? 'True' : 'False';
                                }

                                $el.val(val).trigger('change');
                            }
                            else {
                                $el.val(val);
                            }
                        });

                        $('#dynamicForm').find('input,select,textarea')
                            .filter(':visible:not([readonly]):not([disabled])')
                            .first()
                            .focus();
                    },
                    error: function (err) {
                        alert(err.Message || "Server error while loading record.");
                    }
                });
            }


    });

    </script>
}