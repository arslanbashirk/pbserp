@model List<PBS.ERP.Modules.Security.Controllers.TeamActivity>

@{
    var currentUser = ViewBag.CurrentUser as string;
    ViewData["Title"] = "ERP Team Overview";
    ViewBag.Menu = "Team";
    Layout = "_AdminLayout";

            // External CSS dependencies for tables, buttons, and icons
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

    // Aggregate metrics
    var totalMembers = Model.Count;
    var accounts = Model.Count(x => x.HasAccount);
    var totalEntities = Model.Sum(x => x.CreatedEntities ?? 0);
    var totalFields = Model.Sum(x => x.CreatedFields ?? 0) - totalEntities*11;
    DateTime? lastActivity = null;

    if (Model != null && Model.Any())
    {
        // Get Max only where LastActivity is not null
        var activities = Model.Select(x => x.LastActivity).Where(d => d.HasValue).ToList();
        if (activities.Any())
        {
            lastActivity = activities.Max().Value;
        }
    }
}
<style>
    .current-user-row {
        background: linear-gradient(90deg, #e8f5e9, #ffffff);
        border-left: 4px solid #28a745;
        font-weight: 500;
    }

    .current-user-row:hover {
        background: #dff5e1 !important;
    }
</style>

<div class="row mb-5 g-3">

    <!-- Total Team Members -->
    <div class="col-md-3">
        <div class="card shadow-sm border-0 rounded-3 h-100">
            <div class="card-body d-flex align-items-center">
                <div class="bg-primary text-white rounded p-3 me-3">
                    <i class="bi bi-people-fill fs-4"></i>
                </div>
                <div>
                    <h6 class="text-muted mb-1 text-uppercase small fw-semibold">Total Team Members</h6>
                    <h4 class="fw-bold">@totalMembers</h4>
                </div>
            </div>
        </div>
    </div>

    <!-- Accounts Created -->
    <div class="col-md-3">
        <div class="card shadow-sm border-0 rounded-3 h-100">
            <div class="card-body d-flex align-items-center">
                <div class="bg-success text-white rounded p-3 me-3">
                    <i class="bi bi-person-plus-fill fs-4"></i>
                </div>
                <div>
                    <h6 class="text-muted mb-1 text-uppercase small fw-semibold">Accounts Created</h6>
                    <h4 class="fw-bold">@accounts</h4>
                </div>
            </div>
        </div>
    </div>

    <!-- Entities Created -->
    <div class="col-md-3">
        <div class="card shadow-sm border-0 rounded-3 h-100">
            <div class="card-body d-flex align-items-center">
                <div class="bg-warning text-dark rounded p-3 me-3">
                    <i class="bi bi-diagram-3-fill fs-4"></i>
                </div>
                <div>
                    <h6 class="text-muted mb-1 text-uppercase small fw-semibold">Entities Created</h6>
                    <h4 class="fw-bold">@totalEntities</h4>
                </div>
            </div>
        </div>
    </div>

    <!-- Fields Created -->
    <div class="col-md-3">
        <div class="card shadow-sm border-0 rounded-3 h-100">
            <div class="card-body d-flex align-items-center">
                <div class="bg-danger text-white rounded p-3 me-3">
                    <i class="bi bi-journal-text fs-4"></i>
                </div>
                <div>
                    <h6 class="text-muted mb-1 text-uppercase small fw-semibold">Fields Created</h6>
                    <h4 class="fw-bold">@totalFields</h4>
                </div>
            </div>
        </div>
    </div>

</div>

<style>
    /* Optional hover effect for subtle interactivity */
    .card:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1);
        transition: transform 0.3s, box-shadow 0.3s;
    }
</style>
<div class="mb-3">
    <small class="text-muted">
        <i class="bi bi-clock"></i>
        Last Updated:
        @(lastActivity.HasValue ? lastActivity.Value.ToString("yyyy-MM-dd HH:mm") : "N/A")
    </small>
</div>
<h2 class="mb-4">ERP Team Activities Dashboard</h2>

<!-- Detailed activity table -->
<table class="table table-striped table-bordered" id="teamActivityTable">
    <thead class="table-primary">
        <tr>
            <th>Name</th>
            <th>Designation</th>
            <th>User?</th>
            <th>Logins</th>
            <th>Last Login</th>
            <th>Created Entities</th>
            <th>Created Fields</th>
            <th>Last Activity</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            var isCurrentUser = item.UserName == currentUser;

            <tr class="@(isCurrentUser ? "table-active current-user-row" : "")">
                <td>@item.Name</td>
                <td>@item.Designation</td>
                <td>
                    @if (item.HasAccount)
                    {
                        <span class="badge bg-success">Yes</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">No</span>
                    }
                </td>
                <td>@item.TimesLogin</td>
                <td>@item.LastLogin?.ToString("yyyy-MM-dd HH:mm")</td>
                <td>@item.CreatedEntities</td>
                <td>@(item.CreatedFields-item.CreatedEntities*11)</td>
                <td>@item.LastActivity?.ToString("yyyy-MM-dd HH:mm")</td>
                <td>
                    <form action="/Team/Member" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="username" value="@item.UserName" />
                        <input type="hidden" name="name" value="@item.Name" />
                        <input type="hidden" name="designation" value="@item.Designation" />
                        <button type="submit" class="btn btn-primary btn-sm">
                            <i class="fas fa-eye"></i> View
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>


@section Scripts {
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>

    <script>
        
        // Optional: DataTables initialization for interactive table features
        $(document).ready(function () {
            $('#teamActivityTable').DataTable({
                pageLength: 20,
                lengthMenu: [5, 10, 25, 50],
                responsive: true,
                dom: 'Bfrtip',
                buttons: ['copy', 'csv', 'excel', 'pdf', 'print'],
                "order": []
            });
        });
    </script>
}