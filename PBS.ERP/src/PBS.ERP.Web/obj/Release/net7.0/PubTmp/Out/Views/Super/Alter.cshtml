@{
    Layout = "_Layout";
            <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
            <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
}
<style>
    .select2-container--default .select2-selection--single {
        height: 32px !important;
        border: 1px solid #ced4da !important;
        font-size:13px;
        border-radius: 0.375rem !important;
    }

    .select2-container {
        width: 100% !important;
    }
    .card {
        margin-bottom: 15px;
    }

    .column-row {
        border: 1px solid #dee2e6;
        border-radius: 5px;
        background-color: #f8f9fa;
    }

    #save-table {
        display: none;
    }

    .column-row .form-label {
        font-size: 0.9rem;
        font-weight: 500;
    }

    .hint-box {
        background: #fff3cd;
        border-left: 5px solid #ffc107;
        padding: 10px 15px;
        border-radius: 8px;
        font-size: 13px;
        margin-bottom: 15px;
    }


    .metadata-row-card {
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        overflow: hidden;
        background: #ffffff;
        box-shadow: 0 4px 16px rgba(15, 23, 42, 0.06);
    }

    .metadata-row-header {
        background: #f8fafc;
        border-bottom: 1px solid #e5e7eb;
        padding: 12px 15px;
    }

    .metadata-row-title {
        font-size: 15px;
        font-weight: 700;
        color: #1f2937;
    }

    .metadata-row-subtitle {
        font-size: 12px;
        color: #6b7280;
    }

    .metadata-row-body {
        padding: 15px;
    }

    .metadata-section-box {
        height: 100%;
        background: #fbfdff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 12px;
    }

    .metadata-section-box-merged {
        background: #fffdf7;
    }

    .metadata-section-title {
        display: flex;
        align-items: center;
        gap: 7px;
        font-size: 12px;
        font-weight: 800;
        color: #334155;
        text-transform: uppercase;
        letter-spacing: .4px;
        border-bottom: 1px dashed #cbd5e1;
        padding-bottom: 7px;
        margin-bottom: 10px;
    }

    .metadata-label {
        font-size: 12px;
        font-weight: 700;
        color: #475569;
        margin-bottom: 4px;
    }

    .metadata-control {
        min-height: 36px;
        border-radius: 8px !important;
        border-color: #dbe3ef;
        font-size: 13px;
    }

        .metadata-control:focus {
            border-color: #198754;
            box-shadow: 0 0 0 .15rem rgba(25, 135, 84, .12);
        }

    .metadata-link {
        font-size: 11px;
        text-decoration: none;
        font-weight: 700;
    }

    .metadata-row-actions {
        display: flex;
        gap: 8px;
    }

    .metadata-section-box {
        display: flex !important;
        flex-wrap: wrap !important;
        gap: 0 8px;
        align-content: flex-start;
    }

        .metadata-section-box .metadata-section-title {
            flex: 0 0 100%;
            width: 100%;
        }

    .metadata-section-box-merged .metadata-section-title {
        flex: 0 0 100%;
        width: 100%;
    }

    .metadata-full-field {
        flex: 0 0 100%;
        width: 100%;
    }

    .metadata-half-field,
    .metadata-switch-field {
        flex: 0 0 calc(50% - 4px) !important;
        width: calc(50% - 4px) !important;
        max-width: calc(50% - 4px) !important;
    }

    .metadata-binary-switch {
        display: flex;
        width: 100%;
        border: 1px solid #dbe3ef;
        border-radius: 8px;
        overflow: hidden;
        background: #ffffff;
    }

        .metadata-binary-switch input {
            display: none;
        }

        .metadata-binary-switch label {
            flex: 1;
            margin: 0;
            text-align: center;
            padding: 5px 6px;
            font-size: 11px;
            font-weight: 800;
            cursor: pointer;
            color: #64748b;
            background: #f8fafc;
        }

        .metadata-binary-switch input[value="true"]:checked + .switch-true {
            background: #198754;
            color: #ffffff;
        }

        .metadata-binary-switch input[value="false"]:checked + .switch-false {
            background: #dc3545;
            color: #ffffff;
        }


        .structure-header-line {
    padding: 12px 14px;
    display: flex;
    align-items: center;
    gap: 5px;
    box-shadow: 0 6px 18px rgba(15, 23, 42, 0.06);
}

.structure-title-line {
    font-size: 16px;
    font-weight: bold;
    color: #1e293b;
    white-space: nowrap;
}


.structure-toggle-btn {
    border: 1px solid #c7d2fe;
    background: #c5edf5;
    color: #0d6efd;
    border-radius: 15px;
    padding: 8px 14px;
    font-size: 13px;
    font-weight: 700;
    white-space: nowrap;
}

.structure-toggle-btn:hover {
    background: #0d6efd;
    color: #ffffff;
}

@@media (max-width: 768px) {
    .structure-header-line {
        flex-wrap: wrap;
    }

    .structure-title-line {
        width: 100%;
    }

        .app-request-loading {
            opacity: 0.65;
            pointer-events: none;
            position: relative;
        }

            .app-request-loading::after {
                content: "Processing request...";
                position: absolute;
                right: 16px;
                top: 16px;
                background: #ffffff;
                border: 1px solid #cbd5e1;
                color: #334155;
                border-radius: 999px;
                padding: 6px 12px;
                font-size: 12px;
                font-weight: 700;
                box-shadow: 0 4px 14px rgba(15, 23, 42, .12);
            }
    
}

    .metadata-row-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .column-action-message {
        width: 100%;
        font-size: 13px;
        font-weight: 600;
        border-radius: 10px;
    }
</style>
<div class="container-fluid">
    <div class="meta-header d-flex justify-content-between align-items-center flex-wrap text-white mb-3 p-3 rounded"
         style="background: linear-gradient(135deg, #198754, #157347);">
        <div>
            <h3 class="mb-1">
                <i class="bi bi-braces-asterisk me-2"></i>
                Metadata Modification Engine
            </h3>
            <p class="mb-0 opacity-75">
                Define fields, columns, validation rules, and dynamic entity schema
            </p>
        </div>

    </div>
    <div class="card shadow-sm border-1 mb-3">

        <!-- HEADER (CLICK TO TOGGLE) -->
        <div class="card-header bg-light d-flex justify-content-between align-items-center"
             role="button"
             data-bs-toggle="collapse"
             data-bs-target="#renameTableCollapse"
             aria-expanded="false">

            <div class="d-flex align-items-center">
                <i class="bi bi-upload text-primary fs-5 me-2"></i>
                <span class="fw-semibold">Rename Table</span>
            </div>

            <i class="bi bi-chevron-down text-muted"></i>
        </div>

        <!-- COLLAPSIBLE BODY (DEFAULT COLLAPSED) -->
        <div class="collapse" id="renameTableCollapse">

            <div class="card-body">

                <!-- OPTIONAL: hidden dropdown -->
                <div class="mb-3" style="display:none;">
                    <label class="form-label text-muted small">Existing Table</label>
                    <select id="existingTable" class="form-select">
                        <option value="">-- Select Table --</option>
                    </select>
                </div>

                <!-- FORM ROW -->
                <div class="row g-3 align-items-end">

                    <!-- UID hidden -->
                    <input type="hidden" id="uid" name="uid" value="@ViewBag.UID" />

                    <!-- Table Name -->
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Table Name</label>
                        <input type="text"
                               id="tname"
                               class="form-control"
                               placeholder="Enter new table name"
                               value="@ViewBag.Table" />
                    </div>

                    <!-- Button -->
                    <div class="col-md-2 d-grid">
                        <label class="form-label invisible">Action</label>

                        <button class="btn btn-success shadow-sm"
                                id="renameTable">
                            <i class="bi bi-check2-circle me-1"></i>
                            Rename Table
                        </button>
                    </div>

                </div>

                <!-- HELP TEXT -->
                <div class="mt-2">
                    <small class="text-muted">
                        Rename will update table metadata and system references.
                    </small>
                </div>

            </div>

        </div>
    </div>

    <hr />

    <div class="card shadow-sm border-1">

        <!-- HEADER -->
        <div class="card-header bg-light d-flex justify-content-between align-items-center"
             data-bs-toggle="collapse"
             data-bs-target="#importBody"
             aria-expanded="false">

            <div class="d-flex align-items-center gap-2">
                <i class="bi bi-upload text-primary fs-5"></i>
                <span class="fw-semibold">Import Columns</span>
            </div>

            <!-- Collapse Toggle -->
            <button class="btn btn-sm btn-outline-secondary"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#importBody">

                <i class="bi bi-chevron-down"></i>

            </button>

        </div>

        <!-- BODY -->
        <div class="collapse" id="importBody">

            <div class="card-body bg-white">

                <!-- SINGLE ROW: PERFECT ALIGNMENT -->
                <div class="row g-2 align-items-end">

                    <!-- FILE INPUT (TAKES MOST SPACE) -->
                    <div class="col-lg-8 col-md-7">

                        <label class="form-label fw-semibold mb-1">
                            Import File
                        </label>

                        <input type="file"
                               id="importFile"
                               class="form-control"
                               accept=".xlsx,.xls,.csv,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.ms-excel,text/csv" />

                        <small class="text-primary fw-semibold">
                            Required: ColumnName, SqlType
                        </small>
                        <small class="text-muted">
                            Optional: DisplayLabel, InputType, IsMandatory
                        </small>

                    </div>

                    <!-- BUTTONS (STRICT INLINE CONTROL) -->
                    <div class="col-lg-4 col-md-5">

                        <div class="d-flex gap-2 justify-content-end align-items-center h-100">

                            <button type="button"
                                    id="btnImportColumns"
                                    class="btn btn-primary px-3">

                                <i class="bi bi-upload me-1"></i>
                                Import

                            </button>

                            <button type="button"
                                    id="btnDownloadTemplate"
                                    class="btn btn-outline-secondary px-3">

                                <i class="bi bi-download me-1"></i>
                                Template

                            </button>

                        </div>

                    </div>

                </div>

                <!-- ALERT -->
                <div id="importAlert"
                     class="alert mt-3 d-none"
                     role="alert">
                </div>

                <!-- PROGRESS -->
                <div id="importProgress"
                     class="progress mt-3 d-none"
                     style="height: 20px;">

                    <div class="progress-bar progress-bar-striped progress-bar-animated w-100">
                        Processing import...
                    </div>

                </div>

            </div>

        </div>

    </div>

    <div class="hint-box">
        ⚠ Do NOT create system fields like <b>ID, UID, [Created, Modified, Deleted (By and Time)], IsDeleted, IsActive, Remarks</b>.
        These are auto-managed by the system.
    </div>

    <div class="structure-header-line mb-3">
        <div class="structure-title-line">
            Modify Structure of Existing Table
        </div>


        <button type="button" class="hsToggle structure-toggle-btn ms-auto">
            <i class="bi bi-eye-slash me-1"></i>
            Hide System Columns
        </button>
        <button type="button" class="structure-toggle-btn ms-2"
                onclick="goToOrder('@ViewBag.UID')">
            <i class="bi bi-sort-up me-1"></i>
            Field Layout
        </button>
    </div>
    <style>
        .app-loading-container {
            background: #ffffff;
            border: 1px dashed #cbd5e1;
            border-radius: 14px;
            padding: 18px;
            display: flex;
            align-items: center;
            gap: 14px;
            color: #475569;
        }

        .app-loading-spinner {
            width: 34px;
            height: 34px;
            border: 4px solid #e5e7eb;
            border-top-color: #0d6efd;
            border-radius: 50%;
            animation: appLoadingSpin .8s linear infinite;
        }

        .app-loading-title {
            font-size: 14px;
            font-weight: 800;
            color: #1e293b;
        }

        .app-loading-text {
            font-size: 12px;
            color: #64748b;
        }

        @@keyframes appLoadingSpin {
            to {
                transform: rotate(360deg);
            }
        }
    </style>
    <!-- Columns container -->
    <div id="columns-container" class="mb-3">
        <div class="app-loading-container">
            <div class="app-loading-spinner"></div>

            <div>
                <div class="app-loading-title">
                    Loading
                </div>

                <div class="app-loading-text">
                    Please wait while data is being prepared...
                </div>
            </div>
        </div>
    </div>

    <!-- Buttons -->
    <div class="mb-5">
        <button type="button" id="add-column" class="btn btn-success me-2">
            <i class="bi bi-plus-circle"></i> Add Column
        </button>
        <button type="button" id="save-table" class="btn btn-primary">
            <i class="bi bi-save"></i> Save Table
        </button>
    </div>
</div>


@section scripts {
<!-- Column Template JS -->
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="~/js/save-data.js" asp-append-version="true"></script>
    <script src="~/js/form_change.js"></script>
    <script src="~/js/field_metadata.js"></script>
    <script src="https://cdn.sheetjs.com/xlsx-latest/package/dist/xlsx.full.min.js"></script>
    <script>
        function goToOrder(id) {
            window.location.href = "/Super/Order?id=" + id;
        }
        $(document).ready(function () {
            let columnCount = 0;
            getExistingTables();
        
            const hiddenColumns = [
                "ID",
                "UID",
                "CreatedTime",
                "ModifiedTime",
                "DeletedTime",
                "DeletedBy",
                "CreatedBy",
                "ModifiedBy",
                "DeletedBy",
                "IsDeleted",
                "IsActive",
                "Remarks",
            ];

            let hiddenMode = false;

            function toggleHiddenCards() {

                $('.ColumnName').each(function () {

                    const value = $(this).val()?.trim();

                    const card = $(this).closest('.card');

                    if (hiddenColumns.includes(value)) {
                        if (hiddenMode) {
                            card.hide();
                        } else {
                            card.show();
                        }
                    }
                });
            }

            // Toggle button click
            $(document).on('click', '.hsToggle', function () {
                hiddenMode = !hiddenMode;

                $(this).html(
                    hiddenMode
                        ? `<i class="bi bi-eye me-1"></i> Show System Columns`
                        : `<i class="bi bi-eye-slash me-1"></i> Hide System Columns`
                );

                toggleHiddenCards();
            });
            // Dynamically generated content watcher
            const observer = new MutationObserver(function () {

                toggleHiddenCards();
            });

            observer.observe(document.body, {
                childList: true,
                subtree: true
            });

        
        
            function getExistingTables() {
                window.PbsErp.call("metadata.tables", {  }, {
                    success: function (response) {
                        if (response.Success) {
                            inputConfig.FieldMetadata.DropdownSourceTable.options = response.Data
                                .map(r => ({ value: r.UID, text: "[" + r.Database + "].[" + r.Schema + "].[" + r.Name + "]" }));
                            performLoading();
                            $(".hsToggle").trigger("click");
                        }
                        else {
                            alert(response.Message);
                        }
                    },
                    error: function (err) {
                        alert("Failed to load tables");
                    }
                });
            }





            function performLoading() {
                var name=$("#uid").val();
                window.PbsErp.call("metadata.get", { table: name }, {
                    success: function (response) {
                        if (!response.Success) {
                            alert(response.Message || "Failed to load table metadata");
                            return;
                        }
                        $("#columns-container").empty();
                        // Render columns from metadata
                        $.each(response.Data, function (_, col) {
                            renderColumnRow2(col);
                        });
                    },
                    error: function (err) {
                        alert("Server error while loading table metadata: "+err.Message);
                    }
                });
            }



        



            // Save table
            $(document).on('click', '.alter-column', function () {
                const uid = $("#uid").val().trim();
                const id = $(this).attr("id");

                const $row = $(this).closest(".column-row");
                const idx = $row.data("idx");
                let col = {};
            

                for (let field in inputConfig.FieldMetadata) {

                    const meta = inputConfig.FieldMetadata[field];
                    let $el = $row.find(`[name='${field}_${idx}']`);
                    let val = $el.val();

                    if (val === "" || val === undefined) {
                        val = null;
                    } else if (val === "true") {
                        val = true;
                    } else if (val === "false") {
                        val = false;
                    } else if (meta.Type === "number") {
                        val = Number(val);
                        if (isNaN(val)) val = null;
                    }

                    col[field] = val;
                }

                var url = apiUrl("/api/super/column/");
                var link = "add";
                if (id) {
                    link = "alter";
                }

                if (!confirm(`Do you really want to ${link} column '${col.ColumnName}'?`)) {
                    return;
                }

                const payload = {
                    Table: uid,
                    Column:id,
                    Meta: col
                };
            
                const $btn = $(this);
                const originalBtnHtml = $btn.html();

                $row.addClass("app-request-loading");
                $btn.prop("disabled", true).html(`
                    <span class="spinner-border spinner-border-sm me-1"></span>
                    Saving...
                `);

                $.ajax({
                    url: url + link,
                    type: "POST",
                    contentType: "application/json; charset=utf-8",
                    dataType: "json",
                    data: JSON.stringify(payload),
                    success: function (data) {
                        if (data.Success) {
                            showColumnMessage($btn,"success",data.Message || "Request completed successfully.");

                            if (link === "add") {
                                $btn.attr("id", data.Column);
                                $btn.html(`<i class="bi bi-pencil-square"></i>`);
                            }
                        }
                        else{
                            showColumnMessage($btn, "danger", data.Message || "Request completed successfully.");
                        }
                       
                    },
                    error: function (xhr) {
                        showColumnMessage(
                            $btn,
                            "danger",
                            xhr.responseText || "Unknown error occurred."
                        );
                    },
                    complete: function () {
                        $row.removeClass("app-request-loading");
                        $btn.prop("disabled", false).html(originalBtnHtml);
                    }
                });
            });

            function showColumnMessage($btn, type, message) {

                const $actionArea = $btn.closest(".metadata-row-actions");

                $actionArea.find(".column-action-message").remove();

                $actionArea.append(`
                <div class="column-action-message alert alert-${type} py-2 px-3 mt-2 mb-0">
                    ${message}
                </div>
            `);
            }

            // Drop Column
            $(document).on("click", ".drop-column", function () {
                const uid = $("#uid").val().trim();
                const $row = $(this).closest(".column-row");


                const cname = $row.find(".ColumnName").val();

                if (!cname) {
                    alert("Column name not found");
                    return;
                }

                if (!confirm(`Do you really want to drop column '${cname}'?`)) {
                    return;
                }


                if (!uid) {
                    alert("Table Reference not found");
                    return;
                }

                $.ajax({
                    url: apiUrl("/api/super/column/drop"),
                    type: "POST",
                    contentType: "application/json",
                    data: JSON.stringify({
                        Table: uid,
                        Column: cname
                    }),
                    success: function (res) {
                        alert(res.Message);
                        if (res.Success) {
                            $row.fadeOut(200, function () {
                                $(this).closest(".column-row").remove();
                            });
                        }
                        
                    },
                    error: function (xhr) {
                        const msg = xhr.responseJSON?.Message || "Error dropping column";
                        alert(msg);
                    }
                });
            
            });

            // Rename table
            $('#renameTable').on('click', function (e) {

                var oldtable = $('#uid').val();
                var table = $('#tname').val();

                $.ajax({
                    url: apiUrl('/api/super/table/rename'),
                    type: 'POST',
                    contentType: 'application/json; charset=utf-8',
                    dataType: 'json',
                    data: JSON.stringify({ Old: oldtable, New: table }),
                    success: function (response) {
                        alert(response.Message);
                        if (response.Success) {
                            window.location.href = window.location.href;
                        }
                    },
                    error: function () {
                        alert('Error while renaming table.');
                    }
                });
            });

        });



    </script>
    <script src="~/js/field-import.js"></script>
}
