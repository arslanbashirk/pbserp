
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "User Role Management";
    ViewBag.Menu = "Userrole";
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />

    <style>
        .select2-container .select2-selection--single {
            height: 36px;
        }

        .select2-container--default .select2-selection--single .select2-selection__rendered {
            line-height: 36px;
        }

        .select2-container--default .select2-selection--single .select2-selection__arrow {
            height: 36px;
        }
    </style>
}
<div class="container-fluid mt-4">

    <h3 class="mb-4">User Role Management</h3>

    <div class="row">
        <!-- ================== Assign Roles ================== -->
        <div class="col-md-4">
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h5 class="card-title mb-3">Assign Roles to User</h5>

                    <select id="userSelect" class="form-select mb-3">
                        <option value="">-- Select User --</option>
                    </select>

                    <form id="roleForm">
                        <input type="hidden" id="selectedUserId" />

                        <div id="rolesContainer" class="mb-3">
                            <!-- Role checkboxes injected dynamically -->
                        </div>

                        <button type="button" class="btn btn-success w-100" onclick="assignRoles()">Assign / Update Roles</button>
                        <button type="button" class="btn btn-secondary w-100 mt-2" onclick="resetForm()">Reset</button>
                    </form>
                </div>
            </div>
        </div>

        <!-- ================== All Assignments Table ================== -->
        <div class="col-md-8">
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h5 class="card-title mb-3">All User-Role Assignments</h5>
                    <table id="assignmentsTable" class="table table-bordered table-striped w-100">
                        <thead>
                            <tr>
                                <th>User Name</th>
                                <th>Role Name</th>
                                <th>Active</th>
                                <th>Created Time</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <!-- Populated dynamically -->
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section scripts{
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <script>
        let allRoles = [];
        let assignmentsTable;

        $(document).ready(function () {
            // ================== Load users in dropdown ==================
            $.get('/UserRole/Users', function (data) {
                const userSelect = $('#userSelect');
                data.forEach(u => userSelect.append(`<option value="${u.Id}">${u.UserName}</option>`));
            });

            $('#userSelect').select2({
                width: '100%',
                placeholder: 'Select User',
                allowClear: true
            });



            // ================== User select change ==================
            $('#userSelect').on('change', function () {
                const userId = $(this).val();
                $('#selectedUserId').val(userId);
                if (userId) loadRolesForUser(userId);
                else $('#rolesContainer').empty();
            });

            // ================== Load assignments table ==================
            assignmentsTable = $('#assignmentsTable').DataTable({
                ajax: {
                    url: '/UserRole/Assignments',
                    dataSrc: ''  // <- tells DataTables the root is the array itself
                },
                columns: [
                    { data: 'UserName', title: 'User' },
                    { data: 'RoleName', title: 'Role' },
                    {
                        data: 'IsActive', title: 'Active',
                        render: function (d) { return d ? 'Yes' : 'No'; }
                    },
                    { data: 'CreatedTime', title: 'Created' },
                    {
                        data: 'UID', title: 'Actions',
                        render: function (uid) {
                            return `
                            <button class="btn btn-sm btn-warning me-1" onclick="editAssignment('${uid}')">Edit</button>
                            <button class="btn btn-sm btn-danger" onclick="deleteAssignment('${uid}')">Delete</button>
                          `;
                        }
                    }
                ]
            });
        });

        // ================== Render roles checkboxes ==================
        function renderRolesCheckboxes() {
            const container = $('#rolesContainer');
            container.empty();
            allRoles.forEach(r => {
                container.append(`
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" value="${r.RoleName}" id="role_${r.RoleId}" ${r.IsSelected ? 'checked' : ''}>
                                <label class="form-check-label" for="role_${r.RoleId}">${r.RoleName}</label>
                            </div>
                        `);
            });
        }

        // ================== Load roles for selected user ==================
        function loadRolesForUser(userId) {
            $.get(`/UserRole/RolesForUser?userId=${userId}`, function (data) {
                allRoles = data;
                renderRolesCheckboxes();
            });
        }

        // ================== Assign / Update roles ==================
        function assignRoles() {
            const userId = $('#selectedUserId').val();
            if (!userId) { alert("Select a user first"); return; }

            const selectedRoles = [];
            $('#rolesContainer input:checked').each(function () { selectedRoles.push($(this).val()); });

            $.ajax({
                url: '/UserRole/Assign',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({ userId: userId, selectedRoles: selectedRoles }),
                success: function (res) {
                    if (res.success) {
                        alert("Roles updated!");
                        loadRolesForUser(userId);
                        window.location.reload();
                    } else alert(JSON.stringify(res.error));
                }
            });
        }

        // ================== Reset form ==================
        function resetForm() {
            $('#selectedUserId').val('');
            $('#userSelect').val('');
            $('#rolesContainer').empty();
        }

        // ================== Delete assignment ==================
        function deleteAssignment(uid) {
            if (!confirm("Delete this assignment?")) return;
            $.post('/UserRole/DeleteAssignment', { uid: uid }, function (res) {
                if (res.success) assignmentsTable.ajax.reload();
                else alert(res.error);
            });
        }
    </script>
}