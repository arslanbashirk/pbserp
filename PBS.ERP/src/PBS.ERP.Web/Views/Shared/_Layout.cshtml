@{
    var loginUrl = Url.Action("Login", "Account") ?? "/Account/Login";
    var logoutUrl = Url.Action("Logout", "Account") ?? "/Account/Logout";
    var accessDeniedUrl = Url.Action("AccessDenied", "Account") ?? "/Account/AccessDenied";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - PBS ERP Survey Solution</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Bootstrap Icons CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

    <style>
        html,
        body {
            height: 100%;
        }

        body {
            display: flex;
            flex-direction: column;
            font-family: "Segoe UI", Arial, sans-serif;
        }

        .main-content {
            flex: 1 0 auto;
            padding: 2rem 1rem;
        }

        .footer-custom {
            background: linear-gradient(90deg, #198754 0%, #157347 100%);
            font-size: 1rem;
            flex-shrink: 0;
        }

        .navbar-custom {
            background: linear-gradient(90deg, #198754 0%, #157347 100%);
        }

        .navbar-brand {
            font-weight: 600;
            font-size: 1.1rem;
        }

            .navbar-brand span {
                font-size: 0.85rem;
                display: block;
                font-weight: 400;
            }

        .nav-link {
            font-weight: 500;
        }

        .btn-logout {
            border: none;
            background: transparent;
            color: white;
            font-weight: 500;
        }

            .btn-logout:hover {
                text-decoration: underline;
            }
    </style>
</head>

<body>

    <!-- Top Navigation -->
    <nav class="navbar navbar-expand-lg navbar-dark navbar-custom shadow-sm sticky-top">
        <div class="container-fluid px-4">

            <a class="navbar-brand d-flex align-items-center" href="@Url.Action("Index", "Home")">
                <img src="~/images/pbslogo.png" alt="PBS Logo" height="45" class="me-2" />
                <div>
                    ERP Survey Solution
                    <span>Pakistan Bureau of Statistics</span>
                </div>
            </a>

            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navbarNav"
                    aria-controls="navbarNav"
                    aria-expanded="false"
                    aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-center">

                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item me-3">
                            <span class="nav-link text-white">
                                Welcome, <strong>@User.Identity.Name</strong>
                            </span>
                        </li>

                        <li class="nav-item">
                            <form method="post"
                                  asp-controller="Account"
                                  asp-action="Logout"
                                  class="d-inline"
                                  onsubmit="clearPbsErpLogin();">
                                @Html.AntiForgeryToken()

                                <button type="submit" class="btn btn-sm btn-light px-3">
                                    Logout
                                </button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item me-2">
                            <a class="btn btn-outline-light btn-sm px-3"
                               href="@Url.Action("Login", "Account")">
                                Login
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="btn btn-light btn-sm px-3"
                               href="@Url.Action("Register", "Account")">
                                Register
                            </a>
                        </li>
                    }

                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="container-fluid main-content">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="footer-custom text-white text-center py-3">
        <div class="container">
            <div>© @DateTime.Now.Year Pakistan Bureau of Statistics</div>
            <div>ERP Survey Solution | Government of Pakistan</div>
        </div>
    </footer>

    <!-- jQuery: must load before pbs-erp-auth.js if pages use $.ajax -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        window.PbsErpConfig = {
            loginUrl: '@(Url.Action("Login", "Account") ?? "/Account/Login")',
            accessDeniedUrl: '@(Url.Action("AccessDenied", "Account") ?? "/Account/AccessDenied")'
        };
    </script>

    <script src="~/js/pbs-erp-auth.js" asp-append-version="true"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>