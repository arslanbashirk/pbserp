@{
    ViewData["Title"] = "Page Not Found";
}

<div class="text-center mt-5">
    <h1>Page or Resource Not Found</h1>

    <p>
        The page or resource you are looking for does not exist,
        may have been moved, or is no longer available.
    </p>

    <a asp-controller="Account" asp-action="Login" class="btn btn-primary">
        Go to Login
    </a>
</div>