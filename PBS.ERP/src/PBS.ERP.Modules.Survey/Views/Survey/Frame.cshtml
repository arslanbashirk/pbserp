@model List<PBS.ERP.Shared.Models.SurveyModel.PhaseFrameView>

@{
    ViewData["Title"] = "Survey Frame";
    Layout = "_SurveyLayout";
    <link href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css">

    var totalPhases = Model?.Select(x => x.Phase).Distinct().Count() ?? 0;
    var totalAreas = Model?.Count(x => x.Status == 1) ?? 0;
    var replacedAreas = Model?.Count(x => x.Status == 2) ?? 0;
    var droppedAreas = Model?.Count(x => x.Status == 3) ?? 0;

    var groupedData = Model.GroupBy(x => new { x.PhaseUID, x.Phase, x.Title })
        .Select(g => new
        {
            PhaseUID = g.Key.PhaseUID,
            Phase = g.Key.Phase,
            Title = g.Key.Title,
            Count = g.Count(x => x.UID != null && x.Status==1)
        });

}

<div class="container-fluid mt-4">
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card shadow-sm border-0 rounded-3 h-100">
                    <div class="card-body d-flex align-items-center">
                        <div class="bg-success text-white rounded p-3 me-3">
                            <i class="bi bi-diagram-3-fill fs-4"></i>
                        </div>
                        <div>
                            <h6 class="text-muted mb-1 text-uppercase small fw-semibold">Total Phases</h6>
                            <h4 class="fw-bold">@totalPhases</h4>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card shadow-sm border-0 rounded-3 h-100">
                    <div class="card-body d-flex align-items-center">
                        <div class="bg-success text-white rounded p-3 me-3">
                            <i class="bi bi-grid-fill fs-4"></i>
                        </div>
                        <div>
                            <h6 class="text-muted mb-1 text-uppercase small fw-semibold">Total Areas</h6>
                            <h4 class="fw-bold">@totalAreas</h4>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card shadow-sm border-0 rounded-3 h-100">
                    <div class="card-body d-flex align-items-center">
                        <div class="bg-success text-white rounded p-3 me-3">
                            <i class="bi bi-arrow-repeat fs-4"></i>
                        </div>
                        <div>
                            <h6 class="text-muted mb-1 text-uppercase small fw-semibold">Replaced</h6>
                            <h4 class="fw-bold">@replacedAreas</h4>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card shadow-sm border-0 rounded-3 h-100">
                    <div class="card-body d-flex align-items-center">
                        <div class="bg-success text-white rounded p-3 me-3">
                            <i class="bi bi-x-circle-fill fs-4"></i>
                        </div>
                        <div>
                            <h6 class="text-muted mb-1 text-uppercase small fw-semibold">Dropped</h6>
                            <h4 class="fw-bold">@droppedAreas</h4>
                        </div>
                    </div>
                </div>
            </div>

    </div>


    <!-- ================= GROUPED TABLE ================= -->
    <div class="card mb-4 shadow-sm">
        <div class="card-header bg-default">
            <strong>Survey Phase and Frame Information</strong>
        </div>

        <div class="card-body p-3">

            @if (Model != null && Model.Any())
            {
                foreach (var group in groupedData)
                {
                    <div class="d-flex align-items-center justify-content-between border rounded-3 p-3 mb-3 shadow-sm hover-row bg-white">

                        <div class="d-flex flex-column">
                            <div class="d-flex align-items-center gap-2">
                                <span class="badge bg-dark fs-6">Phase @group.Phase</span>
                                <h6 class="mb-0 fw-bold text-primary">@group.Title</h6>
                            </div>
                        </div>

                        <!-- MIDDLE: COUNT -->
                        <div class="text-center">
                            <span class="badge bg-dark fs-6">Areas @group.Count</span>
                        </div>

                        <!-- RIGHT: ACTIONS -->
                        <div class="d-flex gap-2">
                            <form method="post" action="/crud/file" style="display:inline;">
                                <input type="hidden" name="id" value="@ViewBag.UID" />
                                <input type="hidden" name="SurveyPhase" value="@group.PhaseUID" />
                                <button type="submit" class="btn btn-sm btn-success">
                                    Import / View
                                </button>
                            </form>

                            <a asp-action="DropGroup"
                               asp-route-phase="@group.Phase"
                               class="btn btn-danger btn-sm px-3">
                                Clean
                            </a>
                        </div>

                    </div>
                }
            }
            else
            {
                <div class="text-center text-muted py-3">
                    No data found
                </div>
            }

        </div>
    </div>

    <style>
        .hover-row {
            transition: all 0.25s ease;
        }

            .hover-row:hover {
                transform: translateY(-3px);
                box-shadow: 0 8px 18px rgba(0,0,0,0.12);
            }
    </style>




    <!-- ================= DATATABLE ================= -->
    <div class="card shadow-sm">
        <div class="card-header bg-default">
            <strong>All Areas</strong>
        </div>
        <div class="card-body">
            <table id="areaTable" class="table table-striped table-bordered">
                <thead>
                    <tr>
                        <th>Phase</th>
                        <th>Survey Phase</th>
                        <th>Area Code</th>
                        <th>Status</th>
                        <th>Replaced By</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            if (item.UID != null)
                            {
                                <tr>
                                    <td>@item.Phase</td>
                                    <td>@item.Title</td>
                                    <td>@item.AreaCode</td>
                                    <td>
                                        @if (item.Status == 1)
                                        {
                                            <span class="badge bg-success">New</span>
                                        }
                                        else if (item.Status == 2)
                                        {
                                            <span class="badge bg-warning">Replaced</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Dropped</span>
                                        }
                                    </td>
                                    <td>@item.ReplacedAreaCode</td>
                                    <td>
                                        <button class="btn btn-sm btn-primary btn-change-status"
                                                data-table="@ViewBag.Table"
                                                data-uid="@item.UID"
                                                data-area="@item.AreaCode"
                                                data-phase="@item.PhaseUID"
                                                data-status="@item.Status"
                                                data-replace="@item.ReplacedAreaCode">
                                            Change Status
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>
<!-- ================= CHANGE STATUS MODAL ================= -->
<div class="modal fade" id="statusModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow">

            <div class="modal-header bg-success text-white">
                <h5 class="modal-title">Change Area Status</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Survey Phase</label>
                    <select id="mSurveyPhase" class="form-select" disabled>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var group in groupedData)
                        {
                            <option value="@group.PhaseUID">Phase:@group.Phase (@group.Title)</option>
                        }
                    }
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">Area Code</label>
                    <input type="hidden" id="mTable" class="form-control"/>
                    <input type="hidden" id="mUID" class="form-control"/>
                    <input type="text" id="mAreaCode" class="form-control" disabled />
                </div>

                <div class="mb-3">
                    <label class="form-label">Status</label>
                    <select id="mStatus" class="form-select">
                        <option value="1">New</option>
                        <option value="2">Replaced</option>
                        <option value="3">Dropped</option>
                    </select>
                </div>

                <!-- Replace Area Code (hidden by default) -->
                <div class="mb-3" id="replaceAreaDiv" style="display:none;">
                    <label class="form-label">Replace By (Area Code)</label>
                    <input type="text" id="mReplacedAreaCode" class="form-control" />
                </div>

            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-primary" id="btnSaveStatus">Change Status</button>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script>
        $(document).ready(function () {
            $('#areaTable').DataTable({
                dom: 'Bfrtip',
                buttons: [
                    'copyHtml5',
                    'excelHtml5',
                    'csvHtml5'
                ],
                order: [[0, "asc"]], // default sort by first column
                pageLength: 20,
                lengthMenu: [5, 10, 25, 50, 100],
                "responsive": true,
                
            });

            $(document).on('click', '.btn-change-status', function () {

                let table = $(this).data('table');
                let uid = $(this).data('uid');
                let area = $(this).data('area');
                let phase = $(this).data('phase');
                let status = $(this).data('status');
                let replace = $(this).data('replace');

                $('#mTable').val(table);
                $('#mUID').val(uid);
                $('#mAreaCode').val(area);
                $('#mSurveyPhase').val(phase);
                $('#mStatus').val(status);
                $('#mReplacedAreaCode').val(replace);

                toggleReplaceField(status);

                $('#statusModal').modal('show');
            });


            // ================= STATUS CHANGE EVENT =================
            $('#mStatus').on('change', function () {
                toggleReplaceField($(this).val());
            });


            function toggleReplaceField(status) {
                if (status === "2") {
                    $('#replaceAreaDiv').show();
                } else {
                    $('#replaceAreaDiv').hide();
                    $('#mReplacedAreaCode').val('');
                }
            }


            // ================= SAVE / CHANGE STATUS =================
            $('#btnSaveStatus').click(function () {

                let model = {
                    table: $('#mTable').val(),
                    uid: $('#mUID').val(),
                    AreaCode: $('#mAreaCode').val(),
                    SurveyPhase: $('#mSurveyPhase').val(),
                    Status: parseInt($('#mStatus').val()),
                    IsActive:1,
                    IsDeleted:0
                };

                if (model.Status === 2) {
                    model.ReplacedAreaCode = $('#mReplacedAreaCode').val();
                    isActive = 0;
                } else {
                    delete model.ReplacedAreaCode;
                }

                if (model.Status == 3) {
                    model.IsDeleted = 1;
                    isActive = 0;
                }
                
                $.ajax({
                    url: '/Crud/Update',
                    type: 'POST',
                    data: model,
                    success: function (res) {
                        if(res.Success){
                            alert('Status updated successfully');
                            location.reload();
                        }
                        else{
                            alert(res.Message);
                        }
                        
                    }
                });
            });


            $(document).on('click', '.btn-drop', function () {

                let area = $(this).data('area');

                if (!confirm("Are you sure you want to drop this area?")) return;

                $.ajax({
                    url: '/Survey/DropArea',
                    type: 'POST',
                    data: { areaCode: area },
                    success: function () {
                        alert("Dropped successfully");
                        location.reload();
                    }
                });
            });

        });
    </script>

}
