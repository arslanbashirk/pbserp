@model PBS.ERP.Shared.Models.SurveyModel.SurveyViewModel;

@{
    ViewData["Title"] = "Schema Studio";
}

<style>
    body {
        background: #f4f6fb;
        font-family: "Segoe UI", system-ui;
    }

    /* =========================
       KPI CARDS (PBS STYLE)
    ========================= */

    .metric-card {
        position: relative;
        display: flex;
        align-items: center;
        gap: 16px;
        background: #fff;
        border-radius: 18px;
        padding: 12px;
        border: 1px solid #eef1f6;
        box-shadow: 0 1px 2px rgba(16,24,40,.04), 0 8px 24px rgba(16,24,40,.06);
        transition: all .25s ease;
    }

        .metric-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 30px rgba(16,24,40,.12);
        }

    .metric-icon {
        width: 58px;
        height: 58px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
    }

    .metric-label {
        font-size: .78rem;
        color: #667085;
        text-transform: uppercase;
        font-weight: 600;
        letter-spacing: .04em;
    }

    .metric-value {
        font-size: 1.8rem;
        font-weight: 700;
        color: #101828;
    }

    /* COLORS */
    .q {
        background: #eef4ff;
        color: #3366ff;
    }

    .s {
        background: #ecfdf3;
        color: #12b76a;
    }

    .f {
        background: #fff6ed;
        color: #f79009;
    }

    .fl {
        background: #f4f3ff;
        color: #7a5af8;
    }

    .st {
        background: #ecfdf9;
        color: #0f9d8a;
    }

    .as {
        background: #fff1f3;
        color: #f04438;
    }

    /* ========================= TOOLBAR ========================= */
    .toolbar {
        background: #fff;
        border: 1px solid #e6e9f2;
        border-radius: 14px;
        padding: 12px 14px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 10px;
    }

    .toolbar-title {
        font-weight: 700;
        color: #101828;
    }

    /* ========================= LAYOUT ========================= */
    html, body {
        height: 100%;
    }

    body {
        display: flex;
        flex-direction: column;
        margin: 0;
    }

    /* ========================= WORKSPACE LAYOUT ========================= */

    .workspace {
        flex: 1;
        min-height: 0;
        display: flex;
    }

    /* Panels */
    .panel {
        background: #fff;
        border: 1px solid #e6e9f2;
        border-radius: 14px;
        display: flex;
        flex-direction: column;
        min-height: 0; /* IMPORTANT for scroll */
    }

    /* Scroll containers */
    .tree-body,
    .meta-body,
    .inspector {
        overflow-y: auto;
        flex: 1;
        min-height: 0;
    }

    /* ========================= LEFT TREE ========================= */

    .tree-header {
        padding: 10px 12px;
        font-weight: 700;
        border-bottom: 1px solid #eef1f6;
    }

    .tree-body {
        padding: 10px;
    }

    .node {
        padding: 7px 10px;
        border-radius: 8px;
        cursor: pointer;
        display: flex;
        gap: 8px;
        align-items: center;
        font-size: .9rem;
    }

        .node:hover {
            background: #f3f4f6;
        }

    .children {
        margin-left: 16px;
        border-left: 1px dashed #e5e7eb;
        padding-left: 10px;
    }

    .collapsed {
        display: none;
    }

    .q {
        font-weight: 700;
        color: #2563eb;
    }

    .s {
        color: #16a34a;
    }

    .toggle {
        width: 18px;
        height: 18px;
        border: 1px solid #d0d5dd;
        border-radius: 5px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        background: #fff;
    }

    /* ========================= CENTER ========================= */

    .meta-header {
        padding: 10px 12px;
        font-weight: 700;
        border-bottom: 1px solid #eef1f6;
        background: #fff;
    }

    .meta-body {
        padding: 12px;
        background: #fafbfc;
    }

    /* Table */
    .table {
        width: 100%;
        border-collapse: collapse;
        background: #fff;
        border-radius: 10px;
        overflow: hidden;
        border: 1px solid #e5e7eb;
    }

        .table th {
            text-align: left;
            font-size: 12px;
            color: #6b7280;
            background: #f9fafb;
            padding: 10px;
            border-bottom: 1px solid #e5e7eb;
        }

        .table td {
            padding: 10px;
            border-bottom: 1px solid #f3f4f6;
            font-size: 13px;
            vertical-align: top;
        }

    .field-title {
        font-weight: 600;
        color: #111827;
    }

    .sub {
        font-size: 11px;
        color: #6b7280;
    }

    .required {
        color: #dc2626;
        font-weight: 800;
        margin-left: 4px;
    }

    /* ========================= RIGHT INSPECTOR ========================= */

    .inspector {
        padding: 12px;
    }

    .box {
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        padding: 10px;
        background: #fff;
        margin-bottom: 10px;
    }

    .label {
        font-size: 11px;
        color: #6b7280;
        margin-bottom: 4px;
    }

    input,
    select {
        width: 100%;
        padding: 6px;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        font-size: 12px;
    }

    /* ================= CONTEXT MENU ================= */

    .ctx-menu {
        position: absolute;
        display: none;
        width: 220px;
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        box-shadow: 0 12px 30px rgba(0,0,0,.12);
        z-index: 99999;
        overflow: hidden;
        font-size: 13px;
    }

    .ctx-title {
        padding: 10px 12px;
        font-weight: 700;
        font-size: 12px;
        background: #f9fafb;
        border-bottom: 1px solid #eee;
        color: #111827;
    }

    .ctx-item {
        padding: 10px 12px;
        cursor: pointer;
        transition: 0.15s;
    }

        .ctx-item:hover {
            background: #f3f4f6;
        }

    .ctx-sep {
        height: 1px;
        background: #eee;
    }


    .diagram-wrap {
        position: relative;
        min-height: 500px;
        padding: 20px;
    }

    .diagram-center {
        display: flex;
        justify-content: center;
        margin-top: 20px;
    }

    .diagram-table {
        padding: 14px 18px;
        background: #111827;
        color: white;
        font-weight: 700;
        border-radius: 12px;
        min-width: 180px;
        text-align: center;
    }

    .diagram-node {
        margin-top: 12px;
        padding: 10px;
        border-radius: 10px;
        width: 220px;
    }

        .diagram-node.fk {
            background: #eff6ff;
            border: 1px solid #2563eb;
        }

        .diagram-node.dropdown {
            background: #fffbeb;
            border: 1px dashed #f59e0b;
        }
</style>

<!-- ========================= TOOLBAR ========================= -->
<div class="toolbar d-flex flex-wrap justify-content-between align-items-center gap-2 w-100">

    <div class="toolbar-left d-flex flex-column">
        <div class="toolbar-title">
            <h2 class="mb-0 fs-7 fs-md-8">Survey Metadata Engine</h2>
        </div>

        <div class="text-muted medium fw-bold">
            @Model.Name
            <span class="text-muted">(@Model.ExecutionYear)</span>
        </div>
    </div>

    <div class="toolbar-right d-flex flex-wrap gap-2 ms-auto">
        <button type="button"
                class="btn btn-primary"
                onclick="window.open('/Survey/Questionnaire?id=@Model.UID', '_blank', 'noopener')">
            📝 Data Entry
        </button>
        <button type="button"
                class="btn btn-primary"
                onclick="window.open('/Survey/Entity?id=@Model.UID', '_blank', 'noopener')">
            📝 Tables
        </button>
    </div>
</div>
<div class="row g-3 mb-4" style="display:none">

    <div class="col-xl-3 col-md-4">
        <div class="metric-card">
            <div class="metric-icon q"><i class="bi bi-ui-checks-grid"></i></div>
            <div>
                <div class="metric-label">Questionnaires</div>
                <div class="metric-value">000</div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-4">
        <div class="metric-card">
            <div class="metric-icon s"><i class="bi bi-folder2-open"></i></div>
            <div>
                <div class="metric-label">Sections</div>
                <div class="metric-value">000</div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-4">
        <div class="metric-card">
            <div class="metric-icon f"><i class="bi bi-file-earmark-text"></i></div>
            <div>
                <div class="metric-label">Forms</div>
                <div class="metric-value">000</div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-4">
        <div class="metric-card">
            <div class="metric-icon fl"><i class="bi bi-input-cursor-text"></i></div>
            <div>
                <div class="metric-label">Fields</div>
                <div class="metric-value">000</div>
            </div>
        </div>
    </div>

</div>

<!-- ========================= WORKSPACE ========================= -->

<div class="row workspace">

    <!-- LEFT -->
    <div class="col-12 col-md-3 col-lg-3 panel left d-flex flex-column">

        <div class="tree-header d-flex justify-content-between align-items-center">
            <span>Explorer</span>

            <button type="button"
                    class="btn btn-sm btn-primary"
                    onclick="location.href='/Crud/Table?table=@ViewBag.QuestionnaireUID&Survey=@ViewBag.Survey'">
                + Questionnaire
            </button>
        </div>

        <div class="tree-body">

            @foreach (var q in Model.Questionnaires)
            {
                <div class="node q ctx-node" data-type="q" data-table="@ViewBag.SectionUID" data-uid="@q.UID">
                    <span class="toggle" onclick="toggleNode(this)">−</span>
                    📋 @q.Type
                </div>

                <div class="children">

                    @{
                        var sections = q.Sections
                                         .OrderBy(s => s.SortOrder)
                                         .ToList();
                    }

                    @for (int i = 0; i < sections.Count; i++)
                    {
                        var s = sections[i];
                        var isFirstSection = (i == 0);

                        <div class="node s ctx-node" data-type="s" data-table="@ViewBag.FormUID" data-uid="@s.UID">
                            <span class="toggle" onclick="toggleNode(this)">
                                @(isFirstSection ? "−" : "+")
                            </span>
                            📂 @s.Title
                        </div>

                        <div class="children @(isFirstSection ? "" : "collapsed")">

                            @if (s.Forms != null && s.Forms.Any())
                            {
                                var forms = s.Forms
                                             .OrderBy(f => f.SortOrder)
                                             .ToList();

                                foreach (var f in forms)
                                {
                                    <div class="node form ctx-node"
                                         data-type="f"
                                         data-uid="@f.UID"
                                         data-name="@f.TableName"
                                         data-table="@ViewBag.FormUID"
                                         onclick="loadMetadata('@f.UID','@f.TableName')">

                                        <span class="toggle">•</span>
                                        🧱 @f.TableName
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="node empty">
                                    No forms
                                </div>
                            }

                        </div>
                    }

                </div>
            }

        </div>
    </div>

    <!-- CENTER -->
    <div class="col-12 col-md-6 col-lg-6 panel center d-flex flex-column">

        <div class="meta-header d-flex justify-content-between align-items-center">
            <div><span id="tableName"></span> - Metadata</div>

            <div>
                <button class="btn btn-sm btn-light" onclick="setView('table')">Table</button>
                <button class="btn btn-sm btn-dark" onclick="setView('diagram')">Diagram</button>
                <button type="button"
                        id="orderBtn"
                        class="btn btn-sm btn-primary"
                        data-id="@Model.UID">
                    Layout & Sort
                </button>
            </div>
        </div>

        <div class="meta-body" id="metaBody">
            <div style="color:#6b7280;">Loading first form...</div>
        </div>

    </div>

    <!-- RIGHT -->
    <div class="col-12 col-md-3 col-lg-3 panel right d-flex flex-column">

        <div class="meta-header">Inspector</div>

        <div class="inspector" id="inspector">
            <div style="color:#6b7280;">Select a field</div>
        </div>

    </div>

</div>
<div id="ctxMenu" class="ctx-menu">
    <div class="ctx-title" id="ctxTitle">Actions</div>
    <div class="ctx-group" id="ctxActions"></div>
</div>
<!-- ========================= SCRIPT ========================= -->
@section scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>

        let firstLoaded = false;
        let currentData = [];
        let currentView = "table";
        let allFormsCache = {};
        function toggleNode(el) {
            const node = el.closest('.node');
            const children = node.nextElementSibling;

            if (!children || !children.classList.contains('children')) return;

            const isHidden = children.classList.contains('collapsed');

            if (isHidden) {
                children.classList.remove('collapsed');
                el.innerText = '−';
            } else {
                children.classList.add('collapsed');
                el.innerText = '+';
            }
        }
        function loadMetadata(uid, name) {
            if (uid) {
                $("#orderBtn").attr("data-id", uid);
            }
            if (name) {
                $("#tableName").text(name);
            }
            $("#metaBody").html("<div style='color:#6b7280;'>Loading...</div>");

            $.ajax({
                url: '/Api/Metadata/Get',
                type: 'GET',
                data: { table: uid },
                success: function (res) {
                    if (res.error) {
                        $("#metaBody").html("Error loading metadata");
                        return;
                    }

                    currentData = res.data;

                    // cache by UID for diagram resolution
                    if (res.data && res.data.length > 0) {
                        allFormsCache[uid] = {
                            tableName: res.data[0].TableName,
                            data: res.data
                        };
                    }

                    renderByView();

                    if (!firstLoaded) {
                        firstLoaded = true;
                        loadFirstFieldToInspector(res.data);
                    }
                }
            });
        }
        function setView(view) {
            currentView = view;
            renderByView();
        }

        function renderByView() {
            if (!currentData || currentData.length === 0) return;

            if (currentView === "table") {
                render(currentData);
            } else {
                renderDiagram(currentData);
            }
        }
        function render(data) {

            let grouped = {};
            data.forEach(x => {
                let key = x.SectionName || "General";
                if (!grouped[key]) grouped[key] = [];
                grouped[key].push(x);
            });

            let html = "";

            for (let section in grouped) {

                html += `<div class="section">
                                    <div class="section-title">${section}</div>
                                    <table class="table">
                                    <thead>
                                        <tr>
                                            <th>Field</th>
                                            <th>Type</th>
                                            <th>SQL</th>
                                            <th>Rules</th>
                                        </tr>
                                    </thead>
                                    <tbody>`;

                grouped[section].forEach(f => {

                    let req = f.IsRequired ? "<span class='required'>*</span>" : "";

                    html += `
                                <tr onclick='setInspector(${JSON.stringify(f).replace(/'/g, "&apos;")})'>
                                    <td>
                                        <div class="field-title">${f.DisplayLabel || f.ColumnName} ${req}</div>
                                        <div class="sub">${f.ColumnName}</div>
                                    </td>
                                    <td>${f.InputType || "-"}</td>
                                    <td>${f.SqlType || "-"}</td>
                                    <td class="sub">
                                        ${f.IsReadonly ? "ReadOnly" : ""}
                                        ${f.IsComputed ? "Computed" : ""}
                                    </td>
                                </tr>
                            `;
                });

                html += `</tbody></table></div>`;
            }

            $("#metaBody").html(html);
        }

        function renderDiagram(data) {

            let currentTable = data[0]?.TableName || "Table";

            let relations = [];
            let uidList = [];

            data.forEach(f => {

                if (f.DropdownSourceTable) {
                    uidList.push(f.DropdownSourceTable);
                }

                // 🔵 STRONG RELATION (FK)
                if (f.IsForeignKey && f.DropdownSourceTable) {
                    relations.push({
                        type: "FK",
                        fromField: f.ColumnName,
                        toUid: f.DropdownSourceTable,
                        label: "FK"
                    });
                }

                // 🟡 SOFT RELATION (Dropdown lookup)
                if (!f.IsForeignKey && f.DropdownSourceTable) {
                    relations.push({
                        type: "DROPDOWN",
                        fromField: f.ColumnName,
                        toUid: f.DropdownSourceTable,
                        text: f.DropdownTextColumn,
                        value: f.DropdownValueColumn,
                        label: "Lookup"
                    });
                }
            });

            // remove duplicates
            uidList = [...new Set(uidList)];

            // 👇 CALL API TO RESOLVE NAMES
            if (uidList.length > 0) {
                $.ajax({
                    url: '/Api/Metadata/tables',
                    type: 'GET',
                    traditional: true, // important for array query string
                    data: { uids: uidList },
                    success: function (res) {

                        if (!res.error) {

                            tableNameCache = {};

                            res.data.forEach(t => {
                                tableNameCache[t.uid || t.UID] = t.name || t.Name;
                            });
                        }

                        drawDiagramUI(currentTable, relations);
                    }
                });
            } else {
                drawDiagramUI(currentTable, relations);
            }
        }

        function drawDiagramUI(currentTable, relations) {

            let html = `
                <div class="diagram-wrap">
                    <svg id="erLines"
                         style="position:absolute; top:0; left:0; width:100%; height:100%; pointer-events:none;"></svg>

                    <div class="diagram-center">
                        <div class="diagram-table" id="mainTable">
                            ${currentTable}
                        </div>
                    </div>

                    <div style="display:flex; gap:20px; margin-top:40px; justify-content:center; flex-wrap:wrap;">
                `;

            relations.forEach((r, i) => {

                let targetName = tableNameCache[r.toUid] || r.toUid;

                html += `
                    <div class="diagram-node ${r.type === "FK" ? "fk" : "dropdown"}"
                         id="node_${i}">
                        <b>${targetName}</b>
                        <div>Field: ${r.fromField}</div>
                        <small>${r.type === "FK" ? "Foreign Key" : "Dropdown Lookup"}</small>
                    </div>`;
            });

            html += `</div></div>`;

            $("#metaBody").html(html);

            setTimeout(drawERLines, 100);
        }

        function drawERLines() {

            let svg = document.getElementById("erLines");
            let wrap = document.querySelector(".diagram-wrap");
            let main = document.getElementById("mainTable");

            if (!svg || !wrap || !main) return;

            svg.innerHTML = "";

            let wrapRect = wrap.getBoundingClientRect();
            let mainRect = main.getBoundingClientRect();

            $(".diagram-node").each(function () {

                let rect = this.getBoundingClientRect();

                // 🔥 convert to diagram-wrap coordinates (IMPORTANT FIX)
                let x1 = (mainRect.left + mainRect.width / 2) - wrapRect.left;
                let y1 = (mainRect.bottom) - wrapRect.top;

                let x2 = (rect.left + rect.width / 2) - wrapRect.left;
                let y2 = (rect.top) - wrapRect.top;

                let path = document.createElementNS("http://www.w3.org/2000/svg", "path");

                let dx = Math.abs(x2 - x1) * 0.5;

                let d = `
                        M ${x1} ${y1}
                        C ${x1} ${y1 + dx},
                          ${x2} ${y2 - dx},
                          ${x2} ${y2}
                    `;

                path.setAttribute("d", d);
                path.setAttribute("fill", "none");

                let isFK = $(this).hasClass("fk");

                path.setAttribute("stroke", isFK ? "#2563eb" : "#f59e0b");
                path.setAttribute("stroke-width", "2.2");
                path.setAttribute("stroke-dasharray", isFK ? "0" : "6,4");
                path.setAttribute("opacity", "0.9");

                svg.appendChild(path);
            });
        }

        function exportToCSV() {
            let filename = $("#tableName").text() + ".csv";
            let data = currentData;

            if (!data || !data.length) {
                alert("No data available to export.");
                return;
            }

            const headers = [...new Set(
                data.flatMap(row => Object.keys(row))
            )];

            const csvRows = [];

            csvRows.push(headers.map(h => `"${String(h).replace(/"/g, '""')}"`).join(","));

            data.forEach(row => {
                const values = headers.map(header => {
                    let value = row[header] ?? "";

                    if (typeof value === "object" && value !== null) {
                        value = JSON.stringify(value);
                    }

                    value = String(value).replace(/"/g, '""');

                    return `"${value}"`;
                });

                csvRows.push(values.join(","));
            });

            const csvContent = "\uFEFF" + csvRows.join("\r\n");

            const blob = new Blob([csvContent], {
                type: "text/csv;charset=utf-8;"
            });

            const link = document.createElement("a");
            const url = URL.createObjectURL(blob);

            link.href = url;
            link.download = filename;

            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);

            URL.revokeObjectURL(url);
        }

        function setInspector(f) {

            $("#inspector").html(`
                        <div class="box">
                            <div class="label">Label</div>
                            <input value="${f.DisplayLabel || ''}">
                        </div>

                        <div class="box">
                            <div class="label">Column</div>
                            <input value="${f.ColumnName || ''}">
                        </div>

                        <div class="box">
                            <div class="label">Type</div>
                            <select>
                                <option>${f.InputType}</option>
                            </select>
                        </div>

                        <div class="box">
                            <div class="label">SQL</div>
                            <input value="${f.SqlType || ''}">
                        </div>
                    `);
        }

        function loadFirstFieldToInspector(data) {
            if (!data || !data.length) return;
            setInspector(data[0]);
        }

        // AUTO LOAD FIRST FORM
        $(document).ready(function () {
            let first = $(".form").first();
            if (first.length) {
                loadMetadata(first.data("uid"), first.data("name"));
            }
        });

        let contextTarget = null;

        /* ================= RIGHT CLICK HANDLER ================= */

        document.addEventListener("contextmenu", function (e) {

            let target = e.target.closest(".ctx-node");
            if (!target) return;

            e.preventDefault();

            contextTarget = target;

            let type = target.dataset.type;

            let menu = buildMenu(target.dataset);

            $("#ctxActions").html(menu);

            $("#ctxMenu").css({
                top: e.pageY + "px",
                left: e.pageX + "px",
                display: "block"
            });
        });

        /* hide menu */
        document.addEventListener("click", function () {
            $("#ctxMenu").hide();
        });

        /* ================= MENU BUILDER ================= */

        function buildMenu(dataset) {
            let type = dataset.type;

            let html = "";

            if (type === "q") {
                html += item("➕ Add Section", `window.open('/Crud/Table?table=${encodeURIComponent(dataset.table)}&Questionnaire=${encodeURIComponent(dataset.uid)}', '_blank', 'noopener')`);

                html += sep();
                html += item("📄 Duplicate", "duplicateNode()");
                html += sep();
                html += item("🗃 Archive Questionnaire", "archiveNode()");
                html += item("⚙ Properties", "openProperties()");
            }

            if (type === "s") {
                html += item("➕ Add Form", `window.open('/Form/Table?table=${encodeURIComponent(dataset.table)}&Section=${encodeURIComponent(dataset.uid)}', '_blank', 'noopener')`);

                html += sep();
                html += item("📄 Duplicate", "duplicateNode()");
                html += item("📦 Move Section", "moveNode()");
                html += sep();
                html += item("🗃 Archive Section", "archiveNode()");
                html += item("⚙ Section Settings", "openSectionSettings()");
            }

            if (type === "f") {
                loadMetadata(dataset.uid, dataset.name);
                html += item("🧱 Open Designer", `window.open('/Super/Alter?id=${encodeURIComponent(dataset.uid)}', '_blank', 'noopener')`);
                html += item("➕ Add Field", "addField()");
                html += sep();
                html += item("📝 Data Entry", `window.open('/Entry/Form?form=${encodeURIComponent(dataset.uid)}', '_blank', 'noopener')`);
                html += item("⬆ Import Fields", `window.open('/Super/Alter?id=${encodeURIComponent(dataset.uid)}', '_blank', 'noopener')`);
                html += item("⬇ Export Schema", "exportToCSV()");
                html += sep();
                html += item(
                    "✏ Rename",
                    `renameForm('${encodeURIComponent(dataset.name)}','${encodeURIComponent(dataset.table)}', '${encodeURIComponent(dataset.uid)}')`
                );
                html += item('<i class="bi bi-sort-down me-1"></i> Field Sorting', `window.open('/Entity/Order?id=${encodeURIComponent(dataset.uid)}', '_blank', 'noopener')`);
                //html += item("📄 Duplicate Table", "duplicateTable()");
                //html += item("🔐 Permissions", "openPermissions()");
                html += sep();
                //html += item("🗑 Archive Table", "archiveTable()");
                //html += item("🔌 View API Schema", "viewApiSchema()");
                html += sep();
                html += item(
                    "❌ Drop Form",
                    `dropForm('${encodeURIComponent(dataset.name)}','${encodeURIComponent(dataset.table)}', '${encodeURIComponent(dataset.uid)}')`
                );
            }

            return html;
        }

        /* ================= MENU ITEM HELPERS ================= */

        function item(label, action) {
            return `<div class="ctx-item" onclick="${action}">${label}</div>`;
        }

        function sep() {
            return `<div class="ctx-sep"></div>`;
        }

        /* ================= ACTION STUBS ================= */

        function addSection() { alert("Add Section"); }
        function addForm() { alert("Add Form"); }
        function addField() { alert("Add Field"); }

        function renameNode() { alert("Rename"); }
        function duplicateNode() { alert("Duplicate"); }
        function archiveNode() { alert("Archive (soft delete)"); }

        function moveNode() { alert("Move Section"); }
        function openProperties() { alert("Properties"); }
        function openSectionSettings() { alert("Section Settings"); }

        function openDesigner() { alert("Open Designer"); }
        function editSchema() { alert("Edit Schema"); }
        function importFields() { alert("Import Fields"); }
        function exportSchema() { alert("Export Schema"); }

        function duplicateTable() { alert("Duplicate Table"); }
        function openPermissions() { alert("Permissions"); }

        function archiveTable() { alert("Archive Table"); }
        function viewApiSchema() { alert("API Schema"); }

        function dropForm(name, table, uid) {
            if (!confirm("Are you sure you want to drop/delete this form?\n[" + name + "]")) {
                return;
            }

            fetch('/Form/Delete', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded'
                },
                body: `table=${table}&uid=${uid}`
            })
                .then(response => response.json())
                .then(res => {
                    if (res.Success) {
                        dropTable(uid);
                    } else {
                        alert(res.Message || "Unable to delete form.");
                    }
                })
                .catch(err => {
                    alert("Error deleting form: " + err.message);
                });
        }

        function dropTable(table) {
            $.ajax({
                url: '/Super/api/table/drop',
                type: 'POST',
                contentType: 'application/json; charset=utf-8',
                dataType: 'json',
                data: JSON.stringify({ Table: table }),
                success: function (response) {
                    if (response.error) {
                        alert(response.message || "Failed to drop table.");
                        return;
                    }
                    alert(response.message);
                    location.reload();
                },
                error: function (xhr) {
                    let msg = "Server error: ";
                    try {
                        const resp = JSON.parse(xhr.responseText);
                        if (resp.message) msg = resp.message;
                    } catch (e) {
                        msg = xhr.responseText;
                    }
                    alert(msg);
                }
            });
        }

        async function renameForm(currentName, table, uid) {

            const existingName = decodeURIComponent(currentName);

            const result = await Swal.fire({
                title: 'Rename Form',
                html: `
                        <div class="text-start">
                            <div class="small text-muted mb-2">
                                Enter a new name for this form.
                            </div>
                        </div>
                    `,
                input: 'text',
                inputValue: existingName,
                inputPlaceholder: 'Form Name',
                showCancelButton: true,
                confirmButtonText: 'Save Changes',
                cancelButtonText: 'Cancel',
                confirmButtonColor: '#0d6efd',
                reverseButtons: true,
                focusConfirm: false,
                customClass: {
                    popup: 'shadow-lg rounded-4',
                    confirmButton: 'btn btn-primary',
                    cancelButton: 'btn btn-light'
                },
                buttonsStyling: false,
                inputValidator: value => {
                    if (!value.trim()) {
                        return 'Please enter a form name';
                    }
                }
            });

            if (!result.isConfirmed)
                return;

            $.post(
                `/form/update?table=${encodeURIComponent(table)}&uid=${encodeURIComponent(uid)}`,
                { TableName: result.value.trim() },
                function (success) {

                    if (success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Renamed',
                            text: 'Form renamed successfully.',
                            timer: 1500,
                            showConfirmButton: false
                        }).then(() => location.reload());
                    }
                    else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Rename Failed',
                            text: 'Unable to rename the form.'
                        });
                    }
                }
            );
        }

        $(document).on("click", "#orderBtn", function () {
            const uid = $(this).data("id");

            if (!uid) {
                console.warn("UID not found.");
                return;
            }

            window.location.href = `/Entity/Order?id=${encodeURIComponent(uid)}`;
        });

    </script>
}
