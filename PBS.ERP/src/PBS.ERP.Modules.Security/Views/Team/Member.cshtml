@model List<PBS.ERP.Shared.Models.Entity>
@{
    ViewData["Title"] = ViewBag.Module+" Home";
    ViewBag.Menu = ViewBag.Module;
    Layout = "_AdminLayout";
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    var dbs = (Model != null && Model.Any())
           ? Model.Select(x => x.Database).Where(db => !string.IsNullOrEmpty(db)).Distinct().Count()
           : 0;

    var modify = (Model != null && Model.Any())
    ? Model
        .SelectMany(x => new[] { x.CreatedBy, x.ModifiedBy }) // combine both
        .Where(x => !string.IsNullOrEmpty(x))                 // remove null/empty
        .Distinct()                                           // unique users
        .Count()
    : 0;

    var lastActivity = (Model != null && Model.Any())
        ? Model.Max(x => x.CreatedTime).ToString("dd MMM HH:mm")
        : "No Activity";
}

<div class="container-fluid">

    <div class="row mb-4">
        <div class="col-lg-12">
            <h4 class="fw-bold">@ViewBag.Description</h4>
            <p class="text-muted">Overview Metdata (Entity and Attributes Specification)</p>
        </div>
    </div>

    <div class="row g-4">

    <div class="col-md-3">
        <div class="card shadow-sm border-0">
            <div class="card-body d-flex align-items-center">
                <div class="bg-primary text-white rounded p-3 me-3">
                    <i class="bi bi-database fs-4"></i>
                </div>
                <div>
                    <h6 class="text-muted mb-1">Databases</h6>
                    <h4 class="fw-bold">@dbs</h4>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm border-0">
            <div class="card-body d-flex align-items-center">
                <div class="bg-success text-white rounded p-3 me-3">
                        <i class="bi bi-ui-checks-grid fs-4"></i>
                </div>
                <div>
                    <h6 class="text-muted mb-1">Total Entities</h6>
                    <h4 class="fw-bold">@((Model != null) ? Model.Count : 0)</h4>
                </div>
            </div>
        </div>
    </div>

    

    <div class="col-md-3">
        <div class="card shadow-sm border-0">
            <div class="card-body d-flex align-items-center">
                <div class="bg-warning text-dark rounded p-3 me-3">
                        <i class="bi bi-people-fill fs-4"></i>
                </div>
                <div>
                    <h6 class="text-muted mb-1">Modified By Users</h6>
                    <h4 class="fw-bold">@modify</h4>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm border-0">
            <div class="card-body d-flex align-items-center">
                <div class="bg-danger text-white rounded p-3 me-3">
                    <i class="bi bi-person-lines-fill fs-4"></i>
                </div>
                <div>
                    <h6 class="text-muted mb-1">Last Added</h6>
                    <h4 class="fw-bold">@lastActivity</h4>
                </div>
            </div>
        </div>
    </div>
</div>

    <div class="card border-0 shadow-sm mb-3 mt-3">

        <div class="card-body d-flex justify-content-between align-items-center flex-wrap gap-2">

            <div>
                <h5 class="mb-1 fw-semibold">
                    <i class="bi bi-table me-2 text-success"></i>
                    Create / Add New Table
                </h5>
                <small class="text-muted">
                    Add a new table with columns and metadata configuration
                </small>
            </div>

            <a href="@Url.Action("Create", "Super", null)"
               class="btn btn-success d-flex align-items-center gap-2"
               target="_blank"
               rel="noopener noreferrer">

                <i class="bi bi-plus-circle"></i>
                Add Table
            </a>

        </div>

    </div>
    <div class="row">
        <div class="col-sm-12">
            <h2>List of Tables</h2>

            <table id="tablesList" class="table table-bordered table-striped">
                <thead>
                    <tr>
                        <th>Type</th>
                        <th>Name</th>
                        <th>Description</th>
                        <th>Added By</th>
                        <th>Modified By</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var table in Model)
                    {
                        <tr>
                            <td>@table.Type</td>
                            <td>@table.Name</td>
                            <td>@table.Description</td>
                            <td>@table.CreatedBy</td>
                            <td>@table.ModifiedBy</td>
                            <td class="text-nowrap">
                                @if (table.Name.Equals("Survey") || table.Name.Equals("Form"))
                                {
                                    <a href="@Url.Action("table", table.Name, new { table = table.UID })"
                                       class="btn btn-sm btn-success" title="Data">
                                        <i class="fa fa-database"></i>
                                    </a>
                                }
                                else
                                {
                                    <a href="@Url.Action("table", "crud", new { table = table.UID })"
                                       class="btn btn-sm btn-success" title="Data">
                                        <i class="fa fa-database"></i>
                                    </a>
                                }
                                <a href="@Url.Action("alter", "super", new { id = table.UID })"
                                   class="btn btn-sm btn-primary" title="View">
                                    <i class="fa fa-eye"></i>
                                </a>
                                <button class="btn btn-sm btn-danger droptable"
                                        data-id="@table.UID" title="Drop">
                                    <i class="fa fa-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="col-sm-12 mt-3">
            <div class="activity-chart-card">
                <div class="activity-chart-header">
                    <div>
                        <div class="activity-chart-title">
                            <i class="bi bi-activity me-2"></i>
                            @ViewBag.Description
                        </div>
                        <div class="activity-chart-subtitle">
                            Day-wise fields created and modified by selected team member
                        </div>
                    </div>
                </div>

                <div class="activity-chart-body">
                    <canvas id="fieldActivityChart"></canvas>
                </div>
            </div>
        </div>
    </div>
    

</div>
<style>
    .activity-chart-card {
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        box-shadow: 0 6px 18px rgba(15, 23, 42, 0.06);
        overflow: hidden;
        margin-bottom: 18px;
    }

    .activity-chart-header {
        background: linear-gradient(135deg, #f8fafc, #eef2ff);
        border-bottom: 1px solid #e5e7eb;
        padding: 14px 16px;
    }

    .activity-chart-title {
        font-size: 17px;
        font-weight: 800;
        color: #1e293b;
    }

    .activity-chart-subtitle {
        font-size: 12px;
        color: #64748b;
        margin-top: 2px;
    }

    .activity-chart-body {
        height: 350px;
        padding: 16px;
    }
</style>
@section scripts {
    <!-- jQuery and DataTables JS -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>

    <script>
        $(document).ready(function () {

            // ----------------- INIT DATATABLE -----------------
            var table = $('#tablesList').DataTable({
                dom: 'Bfrtip',
                buttons: [
                    'copyHtml5',
                    'excelHtml5',
                    'csvHtml5',
                    'pdfHtml5'
                ],
                order: [[0, "asc"]], // default sort by first column
                pageLength: 20,
                lengthMenu: [5, 10, 25, 50, 100]
            });

            // ----------------- DROP TABLE -----------------
            // Assuming your table has id="myTable"
            $("#tablesList").on("click", ".droptable", function () {
                var table = $(this).data("id");
                dropTable(table);
            });

            function dropTable(table) {
                if (!confirm(`Are you sure you want to drop table?`)) {
                    return;
                }

                $.ajax({
                    url: '/Super/api/table/drop',
                    type: 'POST',
                    contentType: 'application/json; charset=utf-8',
                    dataType: 'json',
                    data: JSON.stringify({ Table: table }),
                    success: function (response) {
                        if (response.error) {
                            alert(response.message || "Failed to drop table.");
                            return;
                        }

                        alert(response.message);
                        location.reload();
                    },
                    error: function (xhr) {
                        let msg = "Server error: ";

                        try {
                            // Parse JSON if possible
                            const resp = JSON.parse(xhr.responseText);
                            if (resp.message) msg = resp.message;
                        } catch (e) {
                            // responseText is not JSON, fallback
                            msg = xhr.responseText;
                        }

                        alert(msg);
                    }
                });
            }

        });
    </script>

    
}

@using System.Text.Json
@if (ViewBag.FieldActivity != null)
{
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        const fieldActivityData = @Html.Raw(JsonSerializer.Serialize(ViewBag.FieldActivity ?? new List<object>()));

        if (Array.isArray(fieldActivityData) && fieldActivityData.length > 0) {

            const labels = fieldActivityData.map(x =>
                (x.ActivityDate || "").substring(0, 10)
            );

            const created = fieldActivityData.map(x => x.CreatedCount || 0);
            const modified = fieldActivityData.map(x => x.ModifiedCount || 0);

            stackedColumnChart("fieldActivityChart", labels, created, modified);
        }

        function stackedColumnChart(id, labels, created, modified) {
            const canvas = document.getElementById(id);
            if (!canvas) return;

            new Chart(canvas, {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [
                        {
                            label: 'Fields Created',
                            data: created,
                            borderWidth: 1
                        },
                        {
                            label: 'Fields Modified',
                            data: modified,
                            borderWidth: 1
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'bottom' }
                    },
                    scales: {
                        x: { stacked: true },
                        y: {
                            stacked: true,
                            beginAtZero: true,
                            ticks: { precision: 0 }
                        }
                    }
                }
            });
        }
    </script>
}
