@using PBS.ERP.Modules.Core.Controllers
@model List<TableTypeDto>

@{
    Layout = "_Layout";
}

<!-- Icons + Select2 -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />

<style>
    .select2-container--default .select2-selection--single {
        height: 32px !important;
        border: 1px solid #ced4da !important;
        font-size: 13px;
        border-radius: 0.375rem !important;
    }

    .select2-container {
        width: 100% !important;
    }
    body {
        background: #f4f6f9;
    }

    .meta-header {
        background: linear-gradient(135deg, #0d6efd, #198754);
        color: white;
        padding: 20px;
        border-radius: 12px;
        margin-bottom: 20px;
    }

    .meta-card {
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 2px 10px rgba(0,0,0,.05);
        padding: 20px;
        margin-bottom: 20px;
    }

    .meta-label {
        font-size: 13px;
        font-weight: 600;
        color: #555;
        margin-bottom: 5px;
    }

    .form-control, .select2-container--default .select2-selection--single {
        border-radius: 8px !important;
    }

    .column-row {
        border: 1px solid #e9ecef;
        border-radius: 10px;
        background: #fdfdfd;
        padding: 15px;
        margin-bottom: 10px;
    }

    .hint-box {
        background: #fff3cd;
        border-left: 5px solid #ffc107;
        padding: 10px 15px;
        border-radius: 8px;
        font-size: 13px;
        margin-bottom: 15px;
    }

    .btn {
        border-radius: 8px;
    }

    .metadata-row-card {
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        overflow: hidden;
        background: #ffffff;
        box-shadow: 0 4px 16px rgba(15, 23, 42, 0.06);
    }

    .metadata-row-header {
        background: #f8fafc;
        border-bottom: 1px solid #e5e7eb;
        padding: 12px 15px;
    }

    .metadata-row-title {
        font-size: 15px;
        font-weight: 700;
        color: #1f2937;
    }

    .metadata-row-subtitle {
        font-size: 12px;
        color: #6b7280;
    }

    .metadata-row-body {
        padding: 15px;
    }

    .metadata-section-box {
        height: 100%;
        background: #fbfdff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 12px;
    }

    .metadata-section-box-merged {
        background: #fffdf7;
    }

    .metadata-section-title {
        display: flex;
        align-items: center;
        gap: 7px;
        font-size: 12px;
        font-weight: 800;
        color: #334155;
        text-transform: uppercase;
        letter-spacing: .4px;
        border-bottom: 1px dashed #cbd5e1;
        padding-bottom: 7px;
        margin-bottom: 10px;
    }

    .metadata-label {
        font-size: 12px;
        font-weight: 700;
        color: #475569;
        margin-bottom: 4px;
    }

    .metadata-control {
        min-height: 36px;
        border-radius: 8px !important;
        border-color: #dbe3ef;
        font-size: 13px;
    }

        .metadata-control:focus {
            border-color: #198754;
            box-shadow: 0 0 0 .15rem rgba(25, 135, 84, .12);
        }

    .metadata-link {
        font-size: 11px;
        text-decoration: none;
        font-weight: 700;
    }

    .metadata-row-actions {
        display: flex;
        gap: 8px;
    }

    .metadata-section-box {
        display: flex !important;
        flex-wrap: wrap !important;
        gap: 0 8px;
        align-content: flex-start;
    }

        .metadata-section-box .metadata-section-title {
            flex: 0 0 100%;
            width: 100%;
        }

        .metadata-section-box-merged .metadata-section-title {
            flex: 0 0 100%;
            width: 100%;
        }

    .metadata-full-field {
        flex: 0 0 100%;
        width: 100%;
    }

    .metadata-half-field,
    .metadata-switch-field {
        flex: 0 0 calc(50% - 4px) !important;
        width: calc(50% - 4px) !important;
        max-width: calc(50% - 4px) !important;
    }

    .metadata-binary-switch {
        display: flex;
        width: 100%;
        border: 1px solid #dbe3ef;
        border-radius: 8px;
        overflow: hidden;
        background: #ffffff;
    }

        .metadata-binary-switch input {
            display: none;
        }

        .metadata-binary-switch label {
            flex: 1;
            margin: 0;
            text-align: center;
            padding: 5px 6px;
            font-size: 11px;
            font-weight: 800;
            cursor: pointer;
            color: #64748b;
            background: #f8fafc;
        }

        .metadata-binary-switch input[value="true"]:checked + .switch-true {
            background: #198754;
            color: #ffffff;
        }

        .metadata-binary-switch input[value="false"]:checked + .switch-false {
            background: #dc3545;
            color: #ffffff;
        }

</style>

<div class="container-fluid mt-3">

    <!-- HEADER -->
    <div class="meta-header d-flex justify-content-between align-items-center flex-wrap text-white p-3 rounded"
         style="background: linear-gradient(135deg, #198754, #157347);">
        <div>
            <h3 class="mb-1">
                <i class="bi bi-braces-asterisk me-2"></i>
                Metadata Creation Engine
            </h3>
            <p class="mb-0 opacity-75">
                Define tables, columns, validation rules, and dynamic survey schema
            </p>
        </div>

    </div>

    <!-- BASIC INFO -->
    <div class="meta-card">

        <div class="row">

            <div class="col-md-3">
                <div class="meta-label">Table Type</div>
                <select id="ttype" class="form-select" style="height:40px;">
                    <option value="">-- Select Type --</option>
                    @foreach (var item in Model)
                    {
                        <option value="@item.Short">@item.Name</option>
                    }
                </select>
            </div>

            <div class="col-md-3">
                <div class="meta-label">Table Name</div>
                <input type="text" id="tname" class="form-control" placeholder="TableName" />
            </div>

            <div class="col-md-6">
                <div class="meta-label">Description</div>
                <input type="text" id="tdesc" class="form-control" placeholder="Describe this metadata table" />
            </div>

        </div>

    </div>

    <!-- WARNING BOX -->
    <div class="hint-box">
        ⚠ Do NOT create system fields like <b>ID, UID, [Created, Modified, Deleted (By and Time)], IsDeleted, IsActive, Remarks</b>.
        These are auto-managed by the system.
    </div>

    <!-- COLUMN BUILDER -->
    <div class="meta-card">

        <h5 class="mb-3">
            <i class="bi bi-layout-text-window-reverse text-primary"></i>
            Column Designer
        </h5>

        <div id="columns-container"></div>

        <div class="mt-3">
            <button type="button" id="add-column" class="btn btn-success">
                <i class="bi bi-plus-circle"></i> Add Column
            </button>

            <button type="button" id="save-table" class="btn btn-primary">
                <i class="bi bi-save"></i> Save Metadata Table
            </button>
        </div>

    </div>

</div>

<!-- SCRIPTS -->
@section scripts {
    <script src="~/js/form_change.js"></script>
    <script src="~/js/field_metadata.js"></script>

    <script>

        $(document).ready(function () {


            let columnCount = 0;

            getExistingTables();

            function getExistingTables() {
                $.ajax({
                    url: "/api/metadata/tables",
                    type: "GET",
                    success: function (response) {
                        if (response.Success) {
                            inputConfig.FieldMetadata.DropdownSourceTable.options =
                                response.Data.map(r => ({
                                    value: r.UID,
                                    text: "[" + r.Database + "].[" + r.Schema + "].[" + r.Name + "]"
                                }));
                        }
                    }
                });
            }

            // SAVE TABLE
            $("#save-table").click(function () {

                const tname = $("#tname").val().trim();
                const tdesc = $("#tdesc").val().trim();
                const ttype = $("#ttype").val().trim();

                if (!tname) return alert("Enter table name");
                if (!tdesc) return alert("Enter description");

                let columns = [];

                $("#columns-container .column-row").each(function () {

                    const idx = $(this).data("idx");
                    let col = {};

                    for (let field in inputConfig.FieldMetadata) {

                        const meta = inputConfig.FieldMetadata[field];
                        let $el = $(`[name='${field}_${idx}']`);
                        let val = $el.val();

                        if (val === "") val = null;
                        else if (val === "true") val = true;
                        else if (val === "false") val = false;
                        else if (meta.Type === "number") val = Number(val);

                        col[field] = val;
                    }

                    columns.push(col);
                });

                //if (!columns.length) return alert("Add at least one column");

                const payload = {
                    Table: tname,
                    TableDescription: tdesc,
                    TableType: ttype,
                    Columns: columns
                };

                $.ajax({
                    url: "/api/super/table/create",
                    type: "POST",
                    contentType: "application/json",
                    data: JSON.stringify(payload),
                    success: function (data) {
                        alert(data.Message);
                        if(data.Success){
                            window.location.replace("/Super/Index");
                        }
                    },
                    error: function (xhr) {
                        alert(xhr.responseText || "Error occurred");
                    }
                });

            });

            // CLEAN TABLE NAME
            $('#tname').on('input', function () {
                let val = $(this).val();
                val = val.replace(/[^a-zA-Z0-9_]/g, '');
                if (/^[0-9]/.test(val)) val = val.substring(1);
                $(this).val(val);
            });

            // AUTO SUGGEST COLUMN NAME
            $(document).on('focusout', '.clable', function () {

                var label = $(this).val();
                var cname = $(this).closest('.row').find('.cname');

                label = (label || '').trim().toLowerCase();

                if (label.length < 20) {

                    var formatted = label
                        .replace(/[^a-zA-Z0-9\s]/g, '')
                        .replace(/\b(enter|of|the|please|select)\b/gi, '')
                        .trim()
                        .replace(/\s+(.)/g, (_, g1) => g1.toUpperCase())
                        .replace(/^(.)/, (_, g1) => g1.toUpperCase());

                    if (formatted) cname.val(formatted);
                }

                if (['amount','value','price','quantity','number'].some(k => label.includes(k))) {
                    $(this).closest('.row').find('.InputType').val('number').trigger('change');
                }

                if (['name','description','designation'].some(k => label.includes(k))) {
                    $(this).closest('.row').find('.InputType').val('text').trigger('change');
                }

            });

        });

    </script>
}