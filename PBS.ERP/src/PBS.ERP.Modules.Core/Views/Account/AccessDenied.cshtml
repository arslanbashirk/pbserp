@{
    ViewData["Title"] = "Access Denied";
    ViewBag.Menu = ""; // No sidebar menu highlighted

    var referer = Context.Request.Headers["Referer"].ToString();
}

<div class="container-fluid py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">

            <div class="card shadow-sm border-0 text-center">
                <div class="card-header bg-danger text-white">
                    <i class="bi bi-exclamation-triangle-fill me-2" style="font-size: 1.5rem;"></i>
                    <span class="fw-bold">Access Denied</span>
                </div>

                <div class="card-body py-5">
                    <h3 class="text-danger mb-3">You do not have permission to access this page.</h3>
                    <p class="text-muted mb-4">
                        If you believe this is a mistake, please contact your administrator or try logging in with a different account.
                    </p>

                    <div class="d-flex justify-content-center gap-3">

                        <!-- Back to Home -->
                        <a href="@Url.Action("Index", "Home")" class="btn btn-success">
                            <i class="bi bi-house-door me-1"></i> Home
                        </a>

                        <!-- Back to Previous Page -->
                        @if (!string.IsNullOrEmpty(referer))
                        {
                            <a href="@referer" class="btn btn-secondary">
                                <i class="bi bi-arrow-left me-1"></i> Go Back
                            </a>
                        }
                        else
                        {
                            <a href="@Url.Action("Index", "Home")" class="btn btn-secondary">
                                <i class="bi bi-arrow-left me-1"></i> Go Back
                            </a>
                        }

                    </div>
                </div>
            </div>

        </div>
    </div>
</div>